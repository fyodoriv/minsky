#!/bin/bash
# `minsky` — PATH-accessible shim for running the minsky cross-repo
#   runner from any folder.
#
# Pattern: thin bash wrapper + delegating Node subprocess (Martin
#   2017 — I/O at the edge; the resolver `resolveMinskyRepo` in
#   `novel/cross-repo-runner/src/shim-resolve.ts` is pure, the shim
#   here is the I/O boundary that probes the filesystem).
# Source: minsky-observer-plugin-via-agentbrew task block + slice D
#   (PR #492) autonomous defaults (`minsky-run` does cwd auto-detect,
#   this shim just lets the operator invoke it from any shell).
# Conformance: full — no business logic here, only DI + forwarding.
#
# Usage:
#   minsky               → autonomous run (foreground, SIGHUP-immune).
#   minsky --daemon       → autonomous run (background, survives terminal
#                           close + IDE restart). Logs to ~/.minsky/daemon.log.
#   minsky --local        → local-only mode (no cloud tokens). Combinable
#                           with --daemon: `minsky --local --daemon`.
#   minsky --host <dir>  → explicit single-host.
#   minsky --hosts-dir <parent> → explicit multi-host walk.
#   minsky --help        → forwarded to `minsky-run --help`.
#   minsky status        → show running minsky processes + tail of daemon log.
#   minsky stop          → SIGTERM any running minsky-run processes.
#   minsky logs          → tail -f the daemon log.
#
# Resolution order (via `resolveMinskyRepo`):
#   1. $MINSKY_REPO env var (if set + exists)
#   2. ~/apps/tooling/minsky  (canonical Intuit layout)
#   3. ~/apps/minsky, ~/code/minsky, ~/src/minsky (community layouts)
#
# Failure modes (rule #7):
#   - No repo found: loud-crash-supervisor-restart; prints the exact
#     resolver hint + exit 1. The operator sees "Set MINSKY_REPO=..."
#     and can act. Silent fallback would hide the misconfiguration.
#   - Node missing: loud-crash. The upstream `node` probe is single-
#     execution; if node isn't installed, `minsky-run` can't work
#     either, so the shim exits with a message pointing at
#     `setup.sh`.
#   - Subcommand `status`/`stop`/`logs` with no running process: graceful
#     degrade. `status` prints "no running minsky-run on this host";
#     `stop` prints "nothing to stop" and exits 0 (idempotent).

set -euo pipefail

# ── 0. Node availability ─────────────────────────────────────
if ! command -v node >/dev/null 2>&1; then
  echo "minsky: node is not on PATH. Install Node 20+ and retry, or run ~/apps/tooling/minsky/setup.sh first." >&2
  exit 1
fi

# ── Daemon paths ──────────────────────────────────────────────
MINSKY_STATE_DIR="${HOME}/.minsky"
MINSKY_DAEMON_LOG="${MINSKY_STATE_DIR}/daemon.log"
MINSKY_DAEMON_PID="${MINSKY_STATE_DIR}/daemon.pid"

# ── 1. Handle subcommands that DON'T need the repo ──────────
#
# `minsky status` / `minsky stop` / `minsky logs` only need
# ps/grep/kill/tail. Handle them before we pay the repo-resolution
# cost so a fresh machine without minsky checked out can still
# report "no running process".
case "${1:-}" in
  status)
    echo "=== minsky daemon ==="
    # Stability number (from experiment store)
    _host_dir=$(ps aux 2>/dev/null | grep minsky-run | grep -v grep | grep -oE '\-\-host [^ ]+' | awk '{print $2}' | head -1)
    if [ -n "$_host_dir" ] && command -v node >/dev/null 2>&1; then
      _stability=$(node "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/../scripts/stability-number.mjs" "$_host_dir" 2>/dev/null || echo "")
      [ -n "$_stability" ] && echo "Stability: $_stability"
    fi
    if [ -f "$MINSKY_DAEMON_PID" ]; then
      pid=$(cat "$MINSKY_DAEMON_PID")
      if kill -0 "$pid" 2>/dev/null; then
        echo "running (PID $pid)"
        ps -p "$pid" -o etime=,command= 2>/dev/null | head -1
      else
        echo "stale PID file (PID $pid not running)"
        rm -f "$MINSKY_DAEMON_PID"
      fi
    else
      # Fall back to pgrep for processes started without --daemon
      if pgrep -fal "cross-repo-runner/bin/minsky-run" 2>/dev/null; then
        echo "(no PID file — started without --daemon)"
      else
        echo "not running"
      fi
    fi
    if [ -f "$MINSKY_DAEMON_LOG" ]; then
      echo ""
      echo "=== last 10 log lines ==="
      tail -10 "$MINSKY_DAEMON_LOG"
    fi
    exit 0
    ;;
  stop)
    # SIGTERM every running minsky-run process. The runner's own signal
    # handler (host-loop.ts → abort signal) finishes the in-flight
    # iteration before exiting.
    if pgrep -f "cross-repo-runner/bin/minsky-run" >/dev/null 2>&1; then
      pkill -TERM -f "cross-repo-runner/bin/minsky-run"
      echo "sent SIGTERM to all running minsky-run processes"
      rm -f "$MINSKY_DAEMON_PID"
      exit 0
    fi
    echo "nothing to stop"
    exit 0
    ;;
  logs)
    if [ -f "$MINSKY_DAEMON_LOG" ]; then
      exec tail -f "$MINSKY_DAEMON_LOG"
    fi
    echo "no daemon log found at $MINSKY_DAEMON_LOG"
    echo "start minsky with --daemon to enable logging"
    exit 1
    ;;
  install-daemon)
    # Install a launchd plist so minsky auto-starts on login/reboot.
    # Reads default_host from ~/.minsky/config.json.
    _real_bin=$(python3 -c "import os; print(os.path.realpath('$0'))" 2>/dev/null || echo "$0")
    _default_host=$(python3 -c "import json; print(json.load(open('$HOME/.minsky/config.json')).get('default_host',''))" 2>/dev/null)
    if [ -z "$_default_host" ]; then
      _default_host="${2:-$(pwd)}"
      echo "No default_host in ~/.minsky/config.json — using: $_default_host"
    fi

    _plist="$HOME/Library/LaunchAgents/com.minsky.daemon.plist"
    # Resolve the node binary and runner script — launchd runs the node
    # process DIRECTLY (foreground), not via --daemon which backgrounds.
    _repo_dir=$(dirname "$(dirname "$_real_bin")")
    _node_bin=$(which node)
    _runner="$_repo_dir/novel/cross-repo-runner/bin/minsky-run.mjs"
    cat > "$_plist" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.minsky.daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>$_node_bin</string>
    <string>$_runner</string>
    <string>--host</string>
    <string>$_default_host</string>
    <string>--loop</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Standard</string>
  <key>StandardOutPath</key>
  <string>$MINSKY_DAEMON_LOG</string>
  <key>StandardErrorPath</key>
  <string>$MINSKY_DAEMON_LOG</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:$HOME/.local/bin:$HOME/.fnm/aliases/default/bin</string>
    <key>HOME</key>
    <string>$HOME</string>
    <key>MINSKY_NON_INTERACTIVE</key>
    <string>1</string>
  </dict>
  <key>ThrottleInterval</key>
  <integer>10</integer>
</dict>
</plist>
PLIST_EOF

    launchctl bootout "gui/$(id -u)/com.minsky.daemon" 2>/dev/null || true
    launchctl bootstrap "gui/$(id -u)" "$_plist"
    echo "✅ Installed com.minsky.daemon"
    echo "   plist: $_plist"
    echo "   host: $_default_host"
    echo "   auto-starts on login + restarts on crash"
    echo ""
    echo "   Check: launchctl list | grep minsky.daemon"
    echo "   Remove: minsky uninstall-daemon"
    exit 0
    ;;
  uninstall-daemon)
    _plist="$HOME/Library/LaunchAgents/com.minsky.daemon.plist"
    launchctl bootout "gui/$(id -u)/com.minsky.daemon" 2>/dev/null || true
    rm -f "$_plist"
    echo "✅ Removed com.minsky.daemon"
    echo "   minsky will no longer auto-start on login/reboot"
    exit 0
    ;;
  update)
    # Graceful pause → pull latest → rebuild → restart from same spot.
    # The experiment-store preserves iteration history so the daemon
    # resumes from the next unfinished task after restart.
    echo "minsky update — pause, pull, rebuild, resume"
    echo ""

    # 1. Stop daemon gracefully
    if pgrep -f "cross-repo-runner/bin/minsky-run" >/dev/null 2>&1; then
      echo "  1/4 Stopping daemon..."
      pkill -TERM -f "cross-repo-runner/bin/minsky-run"
      rm -f "$MINSKY_DAEMON_PID"
      sleep 2
      echo "       ✅ Daemon stopped"
    else
      echo "  1/4 No daemon running — skip"
    fi

    # Resolve the real minsky repo dir (follows symlinks)
    _real_bin=$(python3 -c "import os; print(os.path.realpath('$0'))" 2>/dev/null || echo "$0")
    _repo_dir=$(dirname "$(dirname "$_real_bin")")

    # 2. Pull latest
    echo "  2/4 Pulling latest from $_repo_dir..."
    git -C "$_repo_dir" pull --rebase 2>&1 | head -5
    echo "       ✅ Pulled"

    # 3. Rebuild
    echo "  3/4 Rebuilding..."
    (cd "$_repo_dir" && pnpm install 2>&1 | tail -3)
    echo "       ✅ Built"

    # 4. Restart daemon with same host
    # Detect the host from the last daemon's args
    LAST_HOST=$(ps aux 2>/dev/null | grep minsky-run | grep -v grep | grep -oE '\-\-host [^ ]+' | awk '{print $2}' | head -1)
    if [ -z "$LAST_HOST" ]; then
      LAST_HOST="${2:-$(pwd)}"
    fi
    echo "  4/4 Restarting on $LAST_HOST..."
    "$0" --daemon --host "$LAST_HOST"
    echo ""
    echo "✅ Update complete. Daemon resumed from where it left off."
    echo "   Run 'minsky watch' to monitor."
    exit 0
    ;;
  watch)
    # Live dashboard: status + iterations + log in a single refreshing view.
    # Refreshes every 10s. Ctrl-C to exit (daemon keeps running).
    HOST_ARG="${2:-}"
    # Resolve scripts dir for stability-number.mjs
    MINSKY_REPO_SCRIPTS="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)/scripts"
    while true; do
      clear
      _ver=$(git -C "$(dirname "$0")" rev-parse --short HEAD 2>/dev/null || echo "?")
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  minsky watch — $(date '+%H:%M:%S') [$_ver]  Ctrl-C to detach              ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      echo ""

      # Status
      if [ -f "$MINSKY_DAEMON_PID" ]; then
        daemon_pid=$(cat "$MINSKY_DAEMON_PID" 2>/dev/null)
        if kill -0 "$daemon_pid" 2>/dev/null; then
          uptime=$(ps -p "$daemon_pid" -o etime= 2>/dev/null | tr -d ' ')
          target=$(ps -p "$daemon_pid" -o args= 2>/dev/null | grep -oE '\-\-host [^ ]+' | head -1)
          agent_count=$(pgrep -f 'devin.*--print\|claude.*--print' 2>/dev/null | wc -l | tr -d ' ')
          echo "  🟢 DAEMON  PID=$daemon_pid  uptime=$uptime  agents=$agent_count"
          echo "     target: $target"
        else
          echo "  🔴 DAEMON  stale PID $daemon_pid (not running)"
          echo "     fix: rm -f ~/.minsky/daemon.pid && minsky --daemon --host <repo>"
        fi
      else
        echo "  ⚫ DAEMON  not running"
        echo "     start: minsky --daemon --host <repo>"
      fi
      echo ""

      # Resolve host dir early (needed by stability + iterations + help)
      host_dir="${HOST_ARG:-}"
      if [ -z "$host_dir" ]; then
        host_dir=$(ps aux 2>/dev/null | grep minsky-run | grep -v grep | grep -oE '\-\-host [^ ]+' | awk '{print $2}' | head -1)
      fi
      host_dir="${host_dir:-}"

      # Stability + dynamic timeouts
      if [ -n "$host_dir" ] && command -v node >/dev/null 2>&1; then
        _stab=$(node "$MINSKY_REPO_SCRIPTS/stability-number.mjs" "$host_dir" 2>/dev/null || echo "no data")
        echo "  📈 Stability: $_stab"
      fi
      dt_line=$(grep 'dynamic-timeouts' "$MINSKY_DAEMON_LOG" 2>/dev/null | tail -1)
      if [ -n "$dt_line" ]; then
        echo "  ⏱  $dt_line"
      fi

      # Current task (from last experiment yaml write)
      _current_task=$(grep 'wrote.*experiments.*yaml' "$MINSKY_DAEMON_LOG" 2>/dev/null | tail -1 | grep -oE '[a-z][-a-z0-9]*\.yaml' | sed 's/\.yaml//')
      if [ -n "$_current_task" ]; then
        echo "  🔧 Current: $_current_task"
      fi

      # Last iteration summary (from the new ⏱ line)
      _last_iter=$(grep '^⏱ iteration' "$MINSKY_DAEMON_LOG" 2>/dev/null | tail -1)
      if [ -n "$_last_iter" ]; then
        echo "  $_last_iter"
      fi
      echo ""

      # Latest iterations (from experiment store)
      echo "  📊 RECENT ITERATIONS"
      echo "  ────────────────────────────────────────────────────────"
      if [ -n "$host_dir" ] && [ -d "$host_dir/.minsky/experiment-store/cross-repo" ]; then
        for f in "$host_dir"/.minsky/experiment-store/cross-repo/*.jsonl; do
          [ -f "$f" ] || continue
          task=$(basename "$f" .jsonl)
          count=$(wc -l < "$f" | tr -d ' ')
          last=$(tail -1 "$f" 2>/dev/null)
          if [ -n "$last" ]; then
            verdict=$(echo "$last" | grep -o '"verdict":"[^"]*"' | sed 's/"verdict":"//;s/"//')
            ts=$(echo "$last" | grep -o '"ts":"[^"]*"' | sed 's/"ts":"//;s/"//;s/T/ /' | cut -c1-19)
            pr=$(echo "$last" | grep -o '"pr_url":"[^"]*"' | sed 's/"pr_url":"//;s/"//')
            if [ "$pr" = "null" ] || [ -z "$pr" ]; then pr="—"; fi
            printf "  %-42s %s %-12s pr=%s  (%s total)\n" "$task" "$ts" "$verdict" "$pr" "$count"
          fi
        done
      else
        echo "  (no experiment data yet)"
      fi
      echo ""

      # Human help needed
      echo "  🆘 NEEDS HUMAN ACTION"
      echo "  ────────────────────────────────────────────────────────"
      _help_needed=0

      # Check for scope-leak (most recent iteration)
      _last_verdict=""
      if [ -n "$host_dir" ] && [ -d "$host_dir/.minsky/experiment-store/cross-repo" ]; then
        for f in "$host_dir"/.minsky/experiment-store/cross-repo/*.jsonl; do
          [ -f "$f" ] || continue
          v=$(tail -1 "$f" | grep -o '"verdict":"[^"]*"' | sed 's/"verdict":"//;s/"//')
          [ "$v" = "scope-leak" ] && _last_verdict="scope-leak"
        done
      fi
      if [ "$_last_verdict" = "scope-leak" ]; then
        echo "  ⚠️  Last iteration scope-leaked. Commit your changes, then: minsky stop && minsky"
        _help_needed=1
      fi

      # Check for repeated spawn-failed
      if [ -f "$MINSKY_DAEMON_LOG" ]; then
        _recent_fails=$(tail -20 "$MINSKY_DAEMON_LOG" | grep -c 'spawn-failed' 2>/dev/null || echo 0)
        if [ "$_recent_fails" -ge 3 ]; then
          echo "  ⚠️  3+ recent spawn failures. Check: devin --version / claude --version"
          _help_needed=1
        fi
      fi

      # Check for blocked tasks in TASKS.md
      if [ -n "$host_dir" ] && [ -f "$host_dir/TASKS.md" ]; then
        _blocked=$(grep -c '\*\*Blocked\*\*:' "$host_dir/TASKS.md" 2>/dev/null || echo 0)
        if [ "$_blocked" -gt 0 ]; then
          echo "  📋 $_blocked tasks marked as blocked — review TASKS.md"
          _help_needed=1
        fi
      fi

      # Check for stale daemon (no new log lines in 20+ min)
      if [ -f "$MINSKY_DAEMON_LOG" ]; then
        _log_age=$(( $(date +%s) - $(stat -f %m "$MINSKY_DAEMON_LOG" 2>/dev/null || stat -c %Y "$MINSKY_DAEMON_LOG" 2>/dev/null || echo 0) ))
        if [ "$_log_age" -gt 1200 ]; then
          echo "  ⚠️  Daemon log not updated in $((_log_age / 60))min — may be stuck"
          _help_needed=1
        fi
      fi

      if [ "$_help_needed" -eq 0 ]; then
        echo "  ✅ No human action needed — minsky is running autonomously"
      fi
      echo ""

      # Log tail
      echo "  📝 LOG (last 5 lines)"
      echo "  ────────────────────────────────────────────────────────"
      if [ -f "$MINSKY_DAEMON_LOG" ]; then
        tail -5 "$MINSKY_DAEMON_LOG" | sed 's/^/  /'
      else
        echo "  (no log)"
      fi

      sleep 10
    done
    ;;
esac

# ── 2. Resolve the minsky repo via the pure `resolveMinskyRepo` ─
#
# The resolver lives in TypeScript; ship a tiny node inline-eval that
# calls the compiled `dist/shim-resolve.js` OR falls back to tsx if the
# package isn't built yet (dev ergonomics — the operator should never
# have to `pnpm build` before the shim works).
SHIM_HOME="${HOME:-/root}"
SHIM_ENV_REPO="${MINSKY_REPO:-}"

MINSKY_REPO_PATH="$(node --input-type=module -e "
  import { existsSync } from 'node:fs';
  import { homedir } from 'node:os';

  // Inline copy of the resolver's deterministic chain. Keeps the
  // shim zero-dependency: no need to resolve the minsky repo to
  // locate the resolver that tells us where the minsky repo is.
  const FALLBACKS = [
    'apps/tooling/minsky',
    'apps/minsky',
    'code/minsky',
    'src/minsky',
  ];
  const home = homedir();
  const envRepo = process.env.MINSKY_REPO;
  if (envRepo && envRepo.length > 0) {
    if (existsSync(envRepo)) {
      process.stdout.write(envRepo);
      process.exit(0);
    }
    process.stderr.write(\`minsky: MINSKY_REPO=\${envRepo} but path does not exist\\n\`);
    process.exit(1);
  }
  for (const rel of FALLBACKS) {
    const full = \`\${home}/\${rel}\`;
    if (existsSync(full)) {
      process.stdout.write(full);
      process.exit(0);
    }
  }
  process.stderr.write('minsky: could not find the minsky repo. Looked at MINSKY_REPO (unset), ~/apps/tooling/minsky, ~/apps/minsky, ~/code/minsky, ~/src/minsky. Set MINSKY_REPO=/path/to/minsky or clone to ~/apps/tooling/minsky.\\n');
  process.exit(1);
" 2>&1)"
RESOLVE_EXIT=$?
if [ $RESOLVE_EXIT -ne 0 ]; then
  echo "$MINSKY_REPO_PATH" >&2
  exit 1
fi
export SHIM_HOME SHIM_ENV_REPO

# ── 3. Locate the runner bin + forward ──────────────────────
RUNNER_BIN="$MINSKY_REPO_PATH/novel/cross-repo-runner/bin/minsky-run.mjs"
if [ ! -f "$RUNNER_BIN" ]; then
  echo "minsky: resolved repo $MINSKY_REPO_PATH but runner bin not found at $RUNNER_BIN. Run \`cd $MINSKY_REPO_PATH && pnpm install\` first." >&2
  exit 1
fi

# ── 3b. Parse --local flag ─────────────────────────────────
# `minsky --local [args...]` sets the env vars for local-only mode
# and strips --local from the args before forwarding. Combinable
# with --daemon: `minsky --local --daemon --hosts-dir ~/apps/tooling`.
MINSKY_ARGS=()
for arg in "$@"; do
  if [ "$arg" = "--local" ]; then
    export MINSKY_LLM_PROVIDER="local-only"
    export MINSKY_LOCAL_LLM=1
  else
    MINSKY_ARGS+=("$arg")
  fi
done
if [ "${#MINSKY_ARGS[@]}" -gt 0 ]; then
  set -- "${MINSKY_ARGS[@]}"
else
  set --
fi

# Survive terminal close (SIGHUP). IDE terminals (Windsurf, Cursor,
# VS Code) send SIGHUP to child processes when the terminal tab or
# window closes. An autonomous minsky run (10h+) must not die because
# the operator restarted their IDE. `trap '' HUP` sets the signal
# disposition to "ignore" in this shell; POSIX guarantees ignored
# signals survive exec, so the node process inherits the immunity.
# SIGTERM from `minsky stop` is unaffected (not trapped here).
# Note: `nohup` binary achieves the same but CyberArk EPM blocks it
# on some corporate Macs — this builtin approach is equivalent.
trap '' HUP

# ── 3b. Smart auto-attach ────────────────────────────────────
# When invoked without subcommands and a daemon is already running,
# attach to it with `watch` instead of failing or starting a duplicate.
# This makes `minsky` in a folder always do the right thing:
#   - daemon running for this host? → attach (watch)
#   - no daemon? → start one in daemon mode + attach (watch)
# Operator directive 2026-05-18: "run minsky in a folder → it just works"

_daemon_running_for_host() {
  # Returns 0 if a daemon is running and targeting a path that contains $1
  [ -f "$MINSKY_DAEMON_PID" ] || return 1
  local pid
  pid=$(cat "$MINSKY_DAEMON_PID" 2>/dev/null) || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  # Check if the running daemon targets the requested host
  ps -p "$pid" -o args= 2>/dev/null | grep -q "$1" 2>/dev/null
}

# If no subcommand and no --daemon flag, try smart auto-attach
if [ "${1:-}" != "--daemon" ] && [ "${1:-}" != "status" ] && [ "${1:-}" != "stop" ] && [ "${1:-}" != "logs" ] && [ "${1:-}" != "watch" ] && [ "${1:-}" != "doctor" ]; then
  # Determine the target host from args or cwd
  _target_host=""
  for _a in "$@"; do
    case "$_a" in
      --host) _next_is_host=1 ;;
      --host=*) _target_host="${_a#--host=}" ;;
      *) [ "${_next_is_host:-}" = "1" ] && _target_host="$_a" && _next_is_host="" ;;
    esac
  done
  [ -z "$_target_host" ] && _target_host="$(pwd)"

  if _daemon_running_for_host "$_target_host"; then
    _pid=$(cat "$MINSKY_DAEMON_PID")
    echo "minsky: daemon already running (PID $_pid) for $(basename "$_target_host")"
    echo "        attaching with watch... (Ctrl-C to detach, daemon keeps running)"
    echo ""
    sleep 1
    exec "$0" watch "$_target_host"
  fi

  # No daemon running — start one and attach
  echo "minsky: no daemon running for $(basename "$_target_host"). Starting..."
  "$0" --daemon --host "$_target_host"
  sleep 2
  exec "$0" watch "$_target_host"
fi

# ── 4. Daemon mode (--daemon) ────────────────────────────────
# `minsky --daemon [args...]` backgrounds the runner, logs to
# ~/.minsky/daemon.log, writes a PID file, and exits immediately.
# The process survives terminal close + IDE restart (SIGHUP-immune
# from the trap above + fully detached from the controlling TTY).
#
# Lifecycle:
#   minsky --daemon --hosts-dir ~/apps/tooling   → start
#   minsky status                                → PID + uptime + log tail
#   minsky logs                                  → tail -f daemon.log
#   minsky stop                                  → SIGTERM → graceful drain
if [ "${1:-}" = "--daemon" ]; then
  shift  # consume --daemon, forward remaining args to minsky-run

  # Guard: don't start a second daemon
  if [ -f "$MINSKY_DAEMON_PID" ]; then
    existing_pid=$(cat "$MINSKY_DAEMON_PID")
    if kill -0 "$existing_pid" 2>/dev/null; then
      echo "minsky: daemon already running (PID $existing_pid). Stop it first: minsky stop" >&2
      exit 1
    fi
    # Stale PID from a crash/reboot — clean up
    echo "minsky: cleaning stale PID $existing_pid (process not running)"
    rm -f "$MINSKY_DAEMON_PID"
  fi

  mkdir -p "$MINSKY_STATE_DIR"

  # Clean up dirty state from a crashed iteration.
  # After SIGKILL/reboot, the host repo may be on a feature branch
  # with uncommitted changes. Reset to default branch so the next
  # iteration starts clean.
  _host_arg=""
  _prev_was_host=0
  for _a in "$@"; do
    if [ "$_prev_was_host" = "1" ]; then
      _host_arg="$_a"
      break
    fi
    [ "$_a" = "--host" ] && _prev_was_host=1 || _prev_was_host=0
  done
  if [ -n "$_host_arg" ] && [ -d "$_host_arg/.git" ]; then
    _default_br=$(git -C "$_host_arg" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || echo "main")
    _current_br=$(git -C "$_host_arg" branch --show-current 2>/dev/null)
    if [ "$_current_br" != "$_default_br" ] && [ -n "$_current_br" ]; then
      echo "minsky: resetting host to $_default_br (was on $_current_br from crashed iteration)"
      git -C "$_host_arg" checkout "$_default_br" 2>/dev/null || true
      git -C "$_host_arg" clean -fd 2>/dev/null || true
    fi
  fi

  # Background the runner. stdin from /dev/null, stdout+stderr to the
  # daemon log (append — preserves history across restarts). The
  # subshell + disown detaches from the controlling terminal's process
  # group so the node process is not a child of this shell.
  MINSKY_NON_INTERACTIVE=1 node "$RUNNER_BIN" "$@" \
    < /dev/null \
    >> "$MINSKY_DAEMON_LOG" 2>&1 &
  daemon_pid=$!
  disown "$daemon_pid" 2>/dev/null || true
  echo "$daemon_pid" > "$MINSKY_DAEMON_PID"

  echo "minsky daemon started (PID $daemon_pid)"
  echo "  log: $MINSKY_DAEMON_LOG"
  echo "  status: minsky status"
  echo "  follow: minsky logs"
  echo "  stop:   minsky stop"
  exit 0
fi

# ── 5. Foreground mode (default) ─────────────────────────────
# Forward every arg verbatim. The runner bin itself handles `--help`,
# cwd auto-detect, countdown banner, autonomous defaults, etc.
# SIGHUP-immune from the trap above.
exec node "$RUNNER_BIN" "$@"
