#!/bin/bash
# `minsky` — PATH-accessible shim for running the minsky cross-repo
#   runner from any folder.
#
# Pattern: thin bash wrapper + delegating Node subprocess (Martin
#   2017 — I/O at the edge; the resolver `resolveMinskyRepo` in
#   `novel/cross-repo-runner/src/shim-resolve.ts` is pure, the shim
#   here is the I/O boundary that probes the filesystem).
# Source: minsky-observer-plugin-via-agentbrew task block + slice D
#   (PR #492) autonomous defaults (`minsky-run` does cwd auto-detect,
#   this shim just lets the operator invoke it from any shell).
# Conformance: full — no business logic here, only DI + forwarding.
#
# Usage:
#   minsky               → autonomous run (foreground, SIGHUP-immune).
#   minsky --daemon       → autonomous run (background, survives terminal
#                           close + IDE restart). Logs to ~/.minsky/daemon.log.
#   minsky --local        → local-only mode (no cloud tokens). Combinable
#                           with --daemon: `minsky --local --daemon`.
#   minsky --host <dir>  → explicit single-host.
#   minsky --hosts-dir <parent> → explicit multi-host walk.
#   minsky --bash-runner → dispatch to the Path A bash port at
#                           `bin/minsky-run.sh` instead of the Node
#                           runner (opt-in; multi-host walker only).
#                           Equivalent: `MINSKY_BASH_RUNNER=1 minsky`.
#   minsky --transform   → dispatch to `bin/minsky-default-session.sh`
#                           against $PWD. Composes bootstrap +
#                           baseline-capture + run + before/after
#                           report. The killer-feature command —
#                           "point at any repo, demo improvement"
#                           (TASKS.md `minsky-default-8h-repo-
#                           transformation` P0). Remaining args are
#                           forwarded: `--max-hours N`,
#                           `--baseline-only`, `--report-only`,
#                           `--no-bootstrap`.
#   minsky --help        → prints this usage block and exits.
#   minsky status        → show running minsky processes + tail of daemon log.
#   minsky stop          → SIGTERM any running minsky-run processes.
#   minsky logs          → tail -f the daemon log.
#   minsky trend         → read $PWD/.minsky/transform-runs.jsonl, emit
#                          MAPE-K Analyse trajectories (#825).
#   minsky recommend     → read $PWD/.minsky/transform-runs.jsonl, emit
#                          MAPE-K Plan rule-based interventions (#826).
#   minsky knowledge     → aggregate ledgers across N hosts via
#                          --hosts-dir; emit MAPE-K Knowledge cross-host
#                          rankings (#827).
#
# Resolution order (via `resolveMinskyRepo`):
#   1. $MINSKY_REPO env var (if set + exists)
#   2. ~/minsky, ~/code/minsky, ~/src/minsky, ~/apps/minsky (common
#      clone locations the shim searches automatically)
#
# Failure modes (rule #7):
#   - No repo found: loud-crash-supervisor-restart; prints the exact
#     resolver hint + exit 1. The operator sees "Set MINSKY_REPO=..."
#     and can act. Silent fallback would hide the misconfiguration.
#   - Node missing: loud-crash. The upstream `node` probe is single-
#     execution; if node isn't installed, `minsky-run` can't work
#     either, so the shim exits with a message pointing at
#     `setup.sh`.
#   - Subcommand `status`/`stop`/`logs` with no running process: graceful
#     degrade. `status` prints "no running minsky-run on this host";
#     `stop` prints "nothing to stop" and exits 0 (idempotent).

set -euo pipefail

# ── 0. Node availability ─────────────────────────────────────
if ! command -v node >/dev/null 2>&1; then
  echo "minsky: node is not on PATH. Install Node 20+ and retry, or run setup.sh in the minsky repo." >&2
  exit 1
fi

# ── Daemon paths ──────────────────────────────────────────────
# `MINSKY_STATE_DIR` is env-override-friendly so integration tests can
# isolate the fixture against a tmpdir without clobbering the operator's
# real `~/.minsky/`. The default still resolves to `${HOME}/.minsky`
# for operator-facing invocations. Same pattern as `MINSKY_INSTALL_
# DAEMON_QUIET:-0` and other opt-out env vars in this script.
MINSKY_STATE_DIR="${MINSKY_STATE_DIR:-${HOME}/.minsky}"
MINSKY_DAEMON_LOG="${MINSKY_STATE_DIR}/daemon.log"
MINSKY_DAEMON_PID="${MINSKY_STATE_DIR}/daemon.pid"

# ── Portable helpers (zero deps — no python3, no uv) ─────────
# We previously shelled out to `python3 -c "import os; print(os.path.realpath(...))"`
# but a corporate `python3` wrapper (Intuit dotfiles) bootstraps a uv cache
# on first call with a fresh HOME. That added 30+ seconds to `minsky report`
# when invoked from a clean test environment. This script must stay portable
# and FAST — replace all python3 calls with shell-only equivalents.
# Discovered 2026-05-19 — rule-#17 fix.
_minsky_realpath() {
  # Resolve symlinks for $1. Works on macOS + Linux. Falls back to $1
  # if both `realpath` and `readlink -f` are missing.
  local _p="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$_p" 2>/dev/null && return 0
  fi
  # macOS readlink doesn't have -f; emulate it.
  while [ -L "$_p" ]; do
    local _next
    _next=$(readlink "$_p" 2>/dev/null) || break
    case "$_next" in
      /*) _p="$_next" ;;
      *) _p="$(dirname "$_p")/$_next" ;;
    esac
  done
  # Resolve relative path to absolute.
  ( cd "$(dirname "$_p")" 2>/dev/null && printf "%s/%s" "$(pwd -P)" "$(basename "$_p")" )
}

_minsky_config_value() {
  # Read `$1` (key) from $MINSKY_STATE_DIR/config.json without a JSON parser.
  # Handles only top-level string values — sufficient for `default_host`,
  # `cloud_agent`, etc. Returns empty string on missing file or missing key.
  local _key="$1"
  local _cfg="${2:-$MINSKY_STATE_DIR/config.json}"
  [ -f "$_cfg" ] || { printf ""; return 0; }
  # awk: find a line `"key": "value"`, strip quotes/commas, print value.
  awk -v key="$_key" '
    BEGIN { FS="\""; found=0 }
    $0 ~ "\"" key "\"[ \t]*:" {
      # Match either string ("...") or bare token after the colon
      idx = index($0, ":")
      rest = substr($0, idx+1)
      gsub(/^[ \t]+|[ \t,]+$/, "", rest)
      gsub(/^"|"$/, "", rest)
      print rest
      found = 1
      exit
    }
  ' "$_cfg" 2>/dev/null
}

# ── Bash-skeleton probe set (shared by `doctor` and the deprecated
#    `bash-doctor` alias) ──────────────────────────────────────────────
#
# Single source of truth for the Path A bash + Python skeleton's
# pre-flight checks (jq, python3 ≥3.10, executable bits on bash
# entrypoints, agent backend, API key, host bootstrap, machine config,
# disk space, git HEAD state, lockfile, optional --smoke).
#
# Previously this probe set was duplicated: a `bash-doctor` case block
# (~280 lines) and a sub-shell call from the `doctor` case block.
# Merged into ONE function (rule #16 CLI-consolidation corollary,
# 2026-05-25 follow-up): both surfaces call this function inline —
# no sub-shell, no second front door.
#
# Inputs (args parsed from $@):
#   --quiet   — suppress PASS lines
#   --smoke   — additionally syntax-check every pipeline script + lint
#               every bash entrypoint with the shell-script linter
#
# Outputs:
#   PASS / FAIL / WARN status lines on stdout via _bd_print.
#   Sets the global `_bd_skeleton_crit_fail` (0 = no critical fails;
#   1 = at least one critical fail). Callers decide whether to
#   propagate this into the overall doctor exit code.
#
# Source: 2026-05-25 retro slice 1+2 (PR #866 introduced the probes;
# PR #868 folded the front door); rule #1 (don't reinvent — single
# probe body across both callers).
_run_bash_skeleton_probes() {
  local _bd_quiet=0
  local _bd_smoke=0
  local _a
  for _a in "$@"; do
    case "$_a" in
      --quiet) _bd_quiet=1 ;;
      --smoke) _bd_smoke=1 ;;
    esac
  done

  _bd_skeleton_crit_fail=0  # GLOBAL — callers read this

  _bd_print() {
    # _bd_print STATUS NAME MESSAGE — quiet hides PASS lines.
    [ "$_bd_quiet" = "1" ] && [ "$1" = "PASS" ] && return 0
    printf "  %-4s  %-22s %s\n" "$1" "$2" "$3"
  }

  local _bd_real_bin
  _bd_real_bin=$(_minsky_realpath "$0")
  local _bd_repo_dir
  _bd_repo_dir=$(dirname "$(dirname "$_bd_real_bin")")
  local _bd_probes="$_bd_repo_dir/scripts/bash-doctor-probes.sh"

  # CRITICAL — jq (record_iteration depends on it)
  if command -v jq >/dev/null 2>&1; then
    local _v
    _v=$(jq --version 2>/dev/null | sed 's/^jq-//')
    _bd_print PASS "jq" "$_v"
  else
    _bd_print FAIL "jq" "not on PATH (record_iteration cannot serialize JSONL — install via brew install jq / apt-get install jq)"
    _bd_skeleton_crit_fail=1
  fi

  # CRITICAL — python3 ≥3.10. Delegates to scripts/bash-doctor-probes.sh
  # to keep `python3 -c` out of bin/minsky (rule enforced by
  # test/integration/m1-red-green.test.ts § "bin/minsky uses portable
  # shell helpers, not python3"). Corporate Python wrappers can take
  # 30+ seconds to bootstrap uv on a fresh HOME — this function only
  # runs when the caller has opted into the bash-skeleton path; the
  # cost is intentional.
  if [ -x "$_bd_probes" ]; then
    local _pyv
    if _pyv=$(bash "$_bd_probes" python-version 2>/dev/null); then
      _bd_print PASS "python3" "$_pyv"
    else
      local _pyv_fallback
      _pyv_fallback=$(bash "$_bd_probes" python-version 2>/dev/null || echo "?")
      _bd_print FAIL "python3" "$_pyv_fallback (need 3.10+ for scripts/*.py)"
      _bd_skeleton_crit_fail=1
    fi
  else
    _bd_print FAIL "python3" "probe helper missing at $_bd_probes"
    _bd_skeleton_crit_fail=1
  fi

  # CRITICAL — bin/minsky-run.sh executable
  if [ -x "$_bd_repo_dir/bin/minsky-run.sh" ]; then
    _bd_print PASS "minsky-run.sh" "$_bd_repo_dir/bin/minsky-run.sh"
  else
    _bd_print FAIL "minsky-run.sh" "not executable at $_bd_repo_dir/bin/minsky-run.sh (run: chmod +x $_bd_repo_dir/bin/minsky-run.sh)"
    _bd_skeleton_crit_fail=1
  fi

  # CRITICAL — bin/minsky-default-session.sh executable
  if [ -x "$_bd_repo_dir/bin/minsky-default-session.sh" ]; then
    _bd_print PASS "default-session.sh" "$_bd_repo_dir/bin/minsky-default-session.sh"
  else
    _bd_print FAIL "default-session.sh" "not executable at $_bd_repo_dir/bin/minsky-default-session.sh"
    _bd_skeleton_crit_fail=1
  fi

  # CRITICAL — scripts/spawn_agent.py exists and is python-parseable
  if [ -f "$_bd_repo_dir/scripts/spawn_agent.py" ]; then
    if [ -x "$_bd_probes" ] && bash "$_bd_probes" syntax "$_bd_repo_dir/scripts/spawn_agent.py" >/dev/null 2>&1; then
      _bd_print PASS "spawn_agent.py" "syntax OK"
    else
      _bd_print FAIL "spawn_agent.py" "syntax error or probe missing — bash $_bd_probes syntax $_bd_repo_dir/scripts/spawn_agent.py"
      _bd_skeleton_crit_fail=1
    fi
  else
    _bd_print FAIL "spawn_agent.py" "missing at $_bd_repo_dir/scripts/spawn_agent.py"
    _bd_skeleton_crit_fail=1
  fi

  # CRITICAL — at least ONE agent backend reachable: canonical
  # `openhands` CLI (post-June-2026 world) OR OpenHands SDK importable.
  local _bd_agent_ok=0
  local _ohv _sdkv
  if [ -x "$_bd_probes" ] && _ohv=$(bash "$_bd_probes" openhands-cli 2>/dev/null); then
    _bd_print PASS "openhands CLI" "$_ohv"
    _bd_agent_ok=1
  fi
  if [ -x "$_bd_probes" ] && _sdkv=$(bash "$_bd_probes" openhands-sdk 2>/dev/null); then
    _bd_print PASS "OpenHands SDK" "importable (v$_sdkv)"
    _bd_agent_ok=1
  elif [ "$_bd_agent_ok" = "0" ]; then
    _bd_print FAIL "agent backend" "neither \`openhands\` CLI nor OpenHands SDK importable (install via: pip install openhands-ai OR install the canonical CLI when shipped)"
    _bd_skeleton_crit_fail=1
  fi

  # WARN — API key env (OPENHANDS_API_KEY / LLM_API_KEY / ANTHROPIC_API_KEY)
  if [ -n "${OPENHANDS_API_KEY:-}" ] || [ -n "${LLM_API_KEY:-}" ] || [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    _bd_print PASS "API key env" "set (OPENHANDS_API_KEY / LLM_API_KEY / ANTHROPIC_API_KEY)"
  else
    _bd_print WARN "API key env" "none of OPENHANDS_API_KEY / LLM_API_KEY / ANTHROPIC_API_KEY set — agent will fail at spawn time"
  fi

  # WARN — .minsky/repo.yaml in $PWD (only meaningful when called from a host)
  if [ -f "$PWD/.minsky/repo.yaml" ]; then
    _bd_print PASS "host bootstrap" "$PWD/.minsky/repo.yaml exists"
  else
    _bd_print WARN "host bootstrap" "$PWD/.minsky/repo.yaml missing (run: $_bd_repo_dir/bin/minsky-bootstrap.sh $PWD before --transform)"
  fi

  # CRITICAL — ~/.minsky/config.json (bash runner's Invariant 1)
  if [ -f "$HOME/.minsky/config.json" ]; then
    _bd_print PASS "machine config" "$HOME/.minsky/config.json exists"
  else
    _bd_print FAIL "machine config" "$HOME/.minsky/config.json missing (run \`minsky init\` to create it; without this, every iteration fails at Invariant 1)"
    _bd_skeleton_crit_fail=1
  fi

  # WARN — shellcheck on bin/minsky-run.sh
  if command -v shellcheck >/dev/null 2>&1; then
    if shellcheck -x "$_bd_repo_dir/bin/minsky-run.sh" >/dev/null 2>&1; then
      _bd_print PASS "shellcheck" "minsky-run.sh clean"
    else
      _bd_print WARN "shellcheck" "minsky-run.sh has violations (run: shellcheck -x $_bd_repo_dir/bin/minsky-run.sh)"
    fi
  else
    _bd_print WARN "shellcheck" "not installed (install via brew install shellcheck — non-blocking but recommended)"
  fi

  # WARN — gh CLI authenticated
  if command -v gh >/dev/null 2>&1; then
    local _ghv
    _ghv=$(gh --version 2>/dev/null | head -1 | sed 's/^gh version //')
    if gh auth status >/dev/null 2>&1; then
      _bd_print PASS "gh CLI" "$_ghv (authenticated)"
    else
      _bd_print WARN "gh CLI" "$_ghv (not authenticated — run \`gh auth login\` before --transform)"
    fi
  else
    _bd_print FAIL "gh CLI" "not on PATH (record_iteration + PR-state probes require it)"
    _bd_skeleton_crit_fail=1
  fi

  # WARN — disk space (failure captures + JSONL ledger grow over time)
  local _df_threshold_mb=1024
  if command -v df >/dev/null 2>&1; then
    local _avail_kb
    _avail_kb=$(df -k "$HOME" 2>/dev/null | awk 'NR==2 {print $4}')
    if [ -n "$_avail_kb" ] && [ "$_avail_kb" -gt 0 ] 2>/dev/null; then
      local _avail_mb=$((_avail_kb / 1024))
      if [ "$_avail_mb" -ge "$_df_threshold_mb" ]; then
        _bd_print PASS "disk free ($HOME)" "${_avail_mb}MB available"
      else
        _bd_print WARN "disk free ($HOME)" "${_avail_mb}MB available (below ${_df_threshold_mb}MB threshold — failure captures + JSONL ledger may hit ENOSPC mid-iteration)"
      fi
    else
      _bd_print WARN "disk free ($HOME)" "(df unparseable)"
    fi
  else
    _bd_print WARN "disk free" "df not on PATH (cannot probe)"
  fi

  # WARN — git HEAD state in $PWD (rebase/merge/cherry-pick in progress breaks per-iter git push)
  if [ -d "$PWD/.git" ] || git -C "$PWD" rev-parse --git-dir >/dev/null 2>&1; then
    local _git_branch
    _git_branch=$(git -C "$PWD" symbolic-ref --short HEAD 2>/dev/null || echo "")
    if [ -n "$_git_branch" ]; then
      local _git_dir
      _git_dir=$(git -C "$PWD" rev-parse --git-dir 2>/dev/null)
      if [ -d "$_git_dir/rebase-merge" ] || [ -d "$_git_dir/rebase-apply" ]; then
        _bd_print WARN "git HEAD ($PWD)" "rebase in progress (run \`git rebase --abort\` or finish it before --transform)"
      elif [ -f "$_git_dir/MERGE_HEAD" ]; then
        _bd_print WARN "git HEAD ($PWD)" "merge in progress (run \`git merge --abort\` or commit it before --transform)"
      elif [ -f "$_git_dir/CHERRY_PICK_HEAD" ]; then
        _bd_print WARN "git HEAD ($PWD)" "cherry-pick in progress (run \`git cherry-pick --abort\` before --transform)"
      else
        _bd_print PASS "git HEAD ($PWD)" "on branch $_git_branch"
      fi
    else
      _bd_print WARN "git HEAD ($PWD)" "detached HEAD (agent cannot push to a non-branch ref — \`git checkout main\` or similar)"
    fi
  else
    _bd_print PASS "git HEAD" "$PWD is not a git repo (skipped — only checked when called from inside one)"
  fi

  # WARN — lockfile presence when $PWD/package.json exists
  if [ -f "$PWD/package.json" ]; then
    if [ -f "$PWD/pnpm-lock.yaml" ] || [ -f "$PWD/package-lock.json" ] || [ -f "$PWD/yarn.lock" ]; then
      _bd_print PASS "lockfile" "found (pnpm-lock.yaml / package-lock.json / yarn.lock)"
    else
      _bd_print WARN "lockfile" "$PWD/package.json exists but no lockfile (every iteration's install will resolve fresh — slow + non-deterministic)"
    fi
  fi

  # --smoke — opt-in deeper checks: dry-run pipeline scripts + shellcheck
  # every bash entrypoint. ~5s extra runtime.
  if [ "$_bd_smoke" = "1" ]; then
    [ "$_bd_quiet" = "0" ] && echo "" && echo "--smoke: dry-running pipeline scripts to catch integration bugs"
    local _bd_smoke_fail=0
    local _bd_script _bd_path
    for _bd_script in "scripts/pick_task.py" "scripts/build_brief.py" "scripts/build_cto_brief.py" "scripts/spawn_agent.py" "scripts/extract_pr_url.py" "scripts/resolve_gh_host.py" "scripts/transform_trend.py" "scripts/transform_recommend.py" "scripts/transform_knowledge.py" "scripts/baseline_metrics.py" "scripts/minsky_report.py" "scripts/iteration_ship_rate.py" "scripts/dynamic_timeout.py" "scripts/synth_experiment_yaml.py" "scripts/spawn_with_watchdog.py"; do
      _bd_path="$_bd_repo_dir/$_bd_script"
      if [ ! -f "$_bd_path" ]; then
        _bd_print FAIL "smoke: $_bd_script" "missing"
        _bd_smoke_fail=1
        continue
      fi
      if bash "$_bd_probes" syntax "$_bd_path" >/dev/null 2>&1; then
        _bd_print PASS "smoke: $_bd_script" "syntax OK"
      else
        _bd_print FAIL "smoke: $_bd_script" "syntax error or import-time crash"
        _bd_smoke_fail=1
      fi
    done
    for _bd_script in "bin/minsky-bootstrap.sh" "bin/minsky-default-session.sh" "scripts/capture-failure.sh" "scripts/bash-doctor-probes.sh"; do
      _bd_path="$_bd_repo_dir/$_bd_script"
      if [ ! -f "$_bd_path" ]; then
        _bd_print FAIL "smoke: $_bd_script" "missing"
        _bd_smoke_fail=1
        continue
      fi
      if command -v shellcheck >/dev/null 2>&1; then
        if shellcheck -x "$_bd_path" >/dev/null 2>&1; then
          _bd_print PASS "smoke: $_bd_script" "shellcheck clean"
        else
          _bd_print WARN "smoke: $_bd_script" "shellcheck violations (run: shellcheck -x $_bd_path)"
        fi
      else
        if bash -n "$_bd_path" 2>/dev/null; then
          _bd_print PASS "smoke: $_bd_script" "bash -n clean"
        else
          _bd_print FAIL "smoke: $_bd_script" "bash -n syntax error"
          _bd_smoke_fail=1
        fi
      fi
    done
    if [ "$_bd_smoke_fail" = "1" ]; then
      _bd_skeleton_crit_fail=1
    fi
  fi

  return "$_bd_skeleton_crit_fail"
}

# ── 1. Handle subcommands that DON'T need the repo ──────────
#
# `minsky status` / `minsky stop` / `minsky logs` only need
# ps/grep/kill/tail. Handle them before we pay the repo-resolution
# cost so a fresh machine without minsky checked out can still
# report "no running process".
case "${1:-}" in
  --help|-h)
    # Print the canonical usage block from the comment header at the
    # top of this file. Extracted via sed — the source-of-truth lives
    # in the file's own docstring, so editing the docstring updates
    # the help output. Drives "minsky --help" through a real top-
    # level handler instead of falling through to the smart-auto-
    # attach block (which would otherwise start a daemon — wrong UX
    # for a help request).
    sed -n '/^# Usage:$/,/^# Resolution order/p' "$0" \
      | sed -e 's/^# //' -e 's/^#$//' \
      | sed '$d'
    echo
    echo "For more on the minsky-run loop: minsky --bash-runner --self-check"
    echo "For the transform orchestrator:  minsky --transform --help"
    exit 0
    ;;
  status)
    echo "=== minsky daemon ==="
    # Stability number (from experiment store)
    # `set -e -o pipefail` aborts the script when any pipe stage exits
    # non-zero. With no daemon running, `grep -v grep` finds zero matches
    # and exits 1 → pipefail kills `status` with exit 1. The `|| true`
    # absorbs the empty-match case so `status` always reaches the rest
    # of the block. Discovered 2026-05-19 — rule-#17 fix.
    _host_dir=$(ps aux 2>/dev/null | grep minsky-run | grep -v grep | grep -oE '\-\-host [^ ]+' | awk '{print $2}' | head -1 || true)
    if [ -n "$_host_dir" ] && command -v node >/dev/null 2>&1; then
      _stability=$(node "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/../scripts/stability-number.mjs" "$_host_dir" 2>/dev/null || echo "")
      [ -n "$_stability" ] && echo "Stability: $_stability"
    fi
    if [ -f "$MINSKY_DAEMON_PID" ]; then
      pid=$(cat "$MINSKY_DAEMON_PID")
      if kill -0 "$pid" 2>/dev/null; then
        echo "running (PID $pid)"
        ps -p "$pid" -o etime=,command= 2>/dev/null | head -1
      else
        echo "stale PID file (PID $pid not running)"
        rm -f "$MINSKY_DAEMON_PID"
      fi
    else
      # Fall back to pgrep for processes started without --daemon
      if pgrep -fal "cross-repo-runner/bin/minsky-run" 2>/dev/null; then
        echo "(no PID file — started without --daemon)"
      else
        echo "not running"
      fi
    fi
    if [ -f "$MINSKY_DAEMON_LOG" ]; then
      echo ""
      echo "=== last 10 log lines ==="
      tail -10 "$MINSKY_DAEMON_LOG"
    fi
    exit 0
    ;;
  stop)
    # Thorough shutdown: kill ALL minsky processes + their agent children
    # + bootout the launchd service. Zero ghost processes after this.
    _killed=0

    # 1. Bootout launchd service (prevents auto-restart via KeepAlive)
    if launchctl list 2>/dev/null | grep -q 'com.minsky.daemon'; then
      launchctl bootout "gui/$(id -u)/com.minsky.daemon" 2>/dev/null || true
      echo "  ✅ launchd com.minsky.daemon stopped"
      _killed=1
    fi

    # 2. SIGTERM all minsky-run node processes
    if pgrep -f "cross-repo-runner/bin/minsky-run" >/dev/null 2>&1; then
      pkill -TERM -f "cross-repo-runner/bin/minsky-run"
      echo "  ✅ SIGTERM sent to minsky-run processes"
      _killed=1
    fi

    # 3. Kill orphaned agent children (devin/claude/aider spawned by minsky)
    #    These are children of minsky-run that may outlive the parent.
    for _agent_pat in 'devin.*--prompt-file.*/minsky-devin' 'claude.*--print' 'aider.*--message-file'; do
      if pgrep -f "$_agent_pat" >/dev/null 2>&1; then
        pkill -TERM -f "$_agent_pat" 2>/dev/null || true
        echo "  ✅ SIGTERM sent to agent children matching: $_agent_pat"
        _killed=1
      fi
    done

    # 4. Clean up PID file
    rm -f "$MINSKY_DAEMON_PID"

    # 5. Wait briefly, then verify nothing remains
    if [ "$_killed" = "1" ]; then
      sleep 2
      _remaining=$(pgrep -f "cross-repo-runner/bin/minsky-run" 2>/dev/null | wc -l | tr -d ' ')
      _agents=$(pgrep -f "devin.*--prompt-file.*/minsky-devin" 2>/dev/null | wc -l | tr -d ' ')
      if [ "$_remaining" != "0" ] || [ "$_agents" != "0" ]; then
        echo "  ⚠️  ${_remaining} runner(s) + ${_agents} agent(s) still alive — sending SIGKILL"
        pkill -9 -f "cross-repo-runner/bin/minsky-run" 2>/dev/null || true
        pkill -9 -f "devin.*--prompt-file.*/minsky-devin" 2>/dev/null || true
        sleep 1
      fi
      echo ""
      echo "minsky stopped. Zero processes remaining."
    else
      echo "nothing to stop (no minsky processes running)"
    fi
    # ALWAYS write the graceful-stop sentinel — even when nothing was
    # killed. `minsky stop` is the operator's explicit intent to shut
    # down cleanly; the next `minsky` start must honour that intent
    # regardless of whether there happened to be a process to kill.
    # Rule #17 — proactive healing of the auto-reset surprise; see
    # TASKS.md `minsky-bin-auto-resets-to-main-surprise`. The sentinel
    # is consumed by `reset-host-if-crashed` so it only protects ONE
    # subsequent start; a real crash after that point still resets.
    _stop_default_host=$(_minsky_config_value "default_host")
    if [ -n "$_stop_default_host" ] && [ -d "$_stop_default_host/.git" ]; then
      mkdir -p "$_stop_default_host/.minsky"
      date -u +%Y-%m-%dT%H:%M:%SZ > "$_stop_default_host/.minsky/graceful-stop"
    fi
    exit 0
    ;;
  logs)
    if [ -f "$MINSKY_DAEMON_LOG" ]; then
      exec tail -f "$MINSKY_DAEMON_LOG"
    fi
    echo "no daemon log found at $MINSKY_DAEMON_LOG"
    echo "start minsky with --daemon to enable logging"
    exit 1
    ;;
  reset-host-if-crashed)
    # Crash-recovery for the host repo. Replaces the previous in-line
    # `git checkout main && git clean -fd` block, which had two
    # multi-agent-safety violations: (1) `clean -fd` is on the global
    # ban list because it deletes other agents' untracked files, and
    # (2) the reset ran EVERY start — surprising developers who'd
    # gracefully stopped the daemon and were now working on a feature
    # branch.
    #
    # The new rule:
    #   - If the sentinel file `<sidecar>/graceful-stop` exists, the
    #     previous shutdown was graceful → do nothing (action: keep).
    #   - Otherwise the previous shutdown crashed → if the tree is
    #     dirty, STASH uncommitted+untracked work with a recoverable
    #     label (`minsky auto-stash <iso-ts>`) and then check out the
    #     default branch. Output the stash ref so the operator can
    #     recover (action: stash-and-reset). If the tree is clean,
    #     just check out the default branch (action: reset-only).
    #
    # Output format (one key=value per line) is stable for paired tests:
    #   action: keep|stash-and-reset|reset-only
    #   branch: <current branch after the operation>
    #   stash: <stash ref> | n/a
    #
    # Sources: rule #6 (stay alive — never by destroying state); rule
    # #17 (proactive healing — every multi-agent-safety violation is
    # P0); global AGENTS.md § "Git Safety (Multi-Agent)".
    _rh_host=""
    _rh_sentinel=""
    shift
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --host)
          _rh_host="$2"
          shift 2
          ;;
        --sentinel)
          _rh_sentinel="$2"
          shift 2
          ;;
        *)
          shift
          ;;
      esac
    done
    if [ -z "$_rh_host" ] || [ ! -d "$_rh_host/.git" ]; then
      echo "minsky: reset-host-if-crashed needs --host <git-repo>" >&2
      exit 2
    fi
    _rh_default=$(git -C "$_rh_host" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || echo "main")
    _rh_current=$(git -C "$_rh_host" branch --show-current 2>/dev/null)
    # Graceful path — sentinel says the previous shutdown was clean.
    # Consume the sentinel so the NEXT start is treated as "no sentinel"
    # unless the operator stops gracefully again.
    if [ -n "$_rh_sentinel" ] && [ -f "$_rh_sentinel" ]; then
      rm -f "$_rh_sentinel"
      echo "action: keep"
      echo "branch: $_rh_current"
      echo "stash: n/a"
      exit 0
    fi
    # Crash path. Check whether the tree is dirty BEFORE switching branches.
    if [ -z "$(git -C "$_rh_host" status --porcelain 2>/dev/null)" ]; then
      # Clean tree — just check out the default branch if we're somewhere else.
      if [ "$_rh_current" != "$_rh_default" ] && [ -n "$_rh_current" ]; then
        git -C "$_rh_host" checkout "$_rh_default" 2>/dev/null || true
      fi
      echo "action: reset-only"
      echo "branch: $(git -C "$_rh_host" branch --show-current 2>/dev/null)"
      echo "stash: n/a"
      exit 0
    fi
    # Dirty tree — stash with a recoverable label, then reset. Never delete.
    # Rule #6 pivot: if stash itself fails (worktree / submodule edge case),
    # loud-crash rather than silently clobber state.
    _rh_ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    _rh_label="minsky auto-stash $_rh_ts"
    if ! git -C "$_rh_host" stash push -u -m "$_rh_label" >/dev/null 2>&1; then
      echo "minsky: REFUSING to start daemon — host $_rh_host has dirty state and 'git stash push -u' failed" >&2
      echo "minsky: resolve manually (commit, stash, or move files out), then retry" >&2
      exit 1
    fi
    _rh_stash_ref="stash@{0}"
    if [ "$_rh_current" != "$_rh_default" ] && [ -n "$_rh_current" ]; then
      if ! git -C "$_rh_host" checkout "$_rh_default" >/dev/null 2>&1; then
        echo "minsky: REFUSING to start daemon — failed to checkout $_rh_default on $_rh_host" >&2
        echo "minsky: stash succeeded but branch switch did not; inspect 'git -C $_rh_host status'" >&2
        exit 1
      fi
    fi
    echo "action: stash-and-reset"
    echo "branch: $(git -C "$_rh_host" branch --show-current 2>/dev/null)"
    echo "stash: $_rh_stash_ref ($_rh_label)"
    echo "recover-with: git -C \"$_rh_host\" stash pop $_rh_stash_ref"
    echo "minsky: stashed dirty state as: $_rh_label"
    exit 0
    ;;
  init)
    # `minsky init [host]` — write per-machine config so subsequent
    # `minsky` invocations know which repo to run against.
    #
    # Behavior:
    #   - host defaults to `pwd` (the most ergonomic case: cd into a
    #     repo, run `minsky init`, you're done).
    #   - host MUST be a git repo. If it isn't, refuse with exit 2 and
    #     a hint — silent fallback would leave a config pointing at a
    #     non-repo and surprise the operator on the first daemon start.
    #   - writes ~/.minsky/config.json with `default_host` set.
    #   - preserves any existing keys (cloud_agent, etc.) — non-destructive.
    #   - prints next steps (`minsky` to start the daemon) so the operator
    #     never has to consult docs.
    #
    # Source: M1 milestone exit criterion §3 (one-command bootstrap);
    # rule #1 (loud-crash on misconfig); rule #15 (UX = ergonomic
    # defaults).
    _init_host="${2:-$(pwd)}"
    # Resolve to absolute path so the config doesn't depend on cwd.
    _init_host=$(cd "$_init_host" 2>/dev/null && pwd)
    if [ -z "$_init_host" ] || [ ! -d "$_init_host/.git" ]; then
      echo "minsky init: '${2:-$(pwd)}' is not a git repo" >&2
      echo "  hint: cd into a git repo first, or run: minsky init /path/to/repo" >&2
      exit 2
    fi
    mkdir -p "$MINSKY_STATE_DIR"
    _cfg="$MINSKY_STATE_DIR/config.json"
    # Preserve existing config keys; only update default_host.
    # Rule #17: avoid python3 (slow + uv-bootstrap on fresh HOME). Use
    # node which is already a hard dep of the runner. Inline script keeps
    # this file zero-dep at the install layer.
    if [ -f "$_cfg" ]; then
      MINSKY_INIT_HOST="$_init_host" node --input-type=module -e "
import { readFileSync, writeFileSync } from 'node:fs';
const path = '$_cfg';
const cfg = JSON.parse(readFileSync(path, 'utf8'));
cfg.default_host = process.env.MINSKY_INIT_HOST;
writeFileSync(path, JSON.stringify(cfg, null, 2));
" 2>/dev/null || printf '{\n  "default_host": "%s"\n}\n' "$_init_host" > "$_cfg"
    else
      printf '{\n  "default_host": "%s"\n}\n' "$_init_host" > "$_cfg"
    fi
    echo "✅ minsky initialized"
    echo "   default_host: $_init_host"
    echo "   config:       $_cfg"
    echo ""
    echo "Next: run 'minsky' (with no args) to start the daemon on $(basename "$_init_host")"
    exit 0
    ;;
  uninstall)
    # `minsky uninstall [--force]` — remove all per-machine state in
    # ONE command (rule #16 default by default — the single-command
    # path is the obvious default, not the previous two-step
    # dry-run + --force flow that surprised operators into walking
    # away thinking they'd uninstalled when they hadn't).
    #
    # Behavior (post-2026-05-23):
    #   - TTY, no --force: prints preview, prompts `Type YES to proceed`.
    #     On exactly-`YES` (not `y` / `yes` / Enter) → executes ALL
    #     steps in one invocation. On anything else → aborts cleanly.
    #   - non-TTY, no --force (e.g., piped, CI, MINSKY_NON_INTERACTIVE=1):
    #     exits 2 with `error: non-interactive — use --force`. Preserves
    #     the safety net for scripts that pipe stdin to the command.
    #   - --force: skips the prompt, executes ALL steps. Back-compat for
    #     existing scripts that rely on the force path.
    #
    # Execute = stop daemon (if running) → uninstall-daemon → rm -rf
    # ~/.minsky/. Does NOT touch host repo's `.minsky/` experiment-store
    # (operator data, preserved by design).
    #
    # Distinct from `uninstall-daemon` which only removes the launchd
    # plist (preserves config + logs). `uninstall` is the full reset.
    #
    # Source: M1 milestone exit criterion §12 (clean uninstall); rule
    # #16 (default by default — operator directive 2026-05-20 "to
    # uninstall you need to just run minsky uninstall and it will do
    # every single needed step including stopping (after confirmation)");
    # `minsky-uninstall-one-command-with-stop` (P0, this PR).
    _force=0
    for _a in "$@"; do
      [ "$_a" = "--force" ] && _force=1
    done
    # Compose the preview text once — used by both the interactive
    # prompt and the non-TTY rejection's body so operators see the
    # same shape in both paths.
    _preview=""
    if [ -f "$HOME/Library/LaunchAgents/com.minsky.daemon.plist" ]; then
      _preview="${_preview}  - launchd plist: $HOME/Library/LaunchAgents/com.minsky.daemon.plist
"
    fi
    if [ -d "$MINSKY_STATE_DIR" ]; then
      _preview="${_preview}  - state dir:     $MINSKY_STATE_DIR
"
    fi
    if pgrep -f "cross-repo-runner/bin/minsky-run" >/dev/null 2>&1; then
      _preview="${_preview}  - running daemon (PID $(pgrep -f cross-repo-runner/bin/minsky-run | head -1))
"
    fi
    if [ "$_force" = "0" ]; then
      # Non-TTY path: refuse without --force. `MINSKY_NON_INTERACTIVE=1`
      # is the explicit opt-out (matches the existing convention used by
      # `MINSKY_INSTALL_DAEMON_QUIET=1` and the daemon-side
      # `MINSKY_NON_INTERACTIVE`).
      if [ ! -t 0 ] || [ "${MINSKY_NON_INTERACTIVE:-0}" = "1" ]; then
        echo "minsky uninstall — would remove:" >&2
        printf '%s' "$_preview" >&2
        echo "" >&2
        echo "error: non-interactive — use --force to confirm without prompt" >&2
        exit 2
      fi
      # Interactive TTY path: show preview, prompt for `YES` (exact match,
      # no fuzzy yes/y/Enter — accidental confirmation is hard).
      echo "minsky uninstall — will remove:"
      printf '%s' "$_preview"
      echo ""
      printf "Type YES to proceed (anything else aborts): "
      IFS= read -r _confirm
      if [ "$_confirm" != "YES" ]; then
        echo "aborted (got '$_confirm', expected exactly 'YES')"
        exit 1
      fi
    fi
    # Execute path — full removal. Reached by --force OR interactive YES.
    if pgrep -f "cross-repo-runner/bin/minsky-run" >/dev/null 2>&1; then
      "$0" stop >/dev/null 2>&1 || true
    fi
    if [ -f "$HOME/Library/LaunchAgents/com.minsky.daemon.plist" ]; then
      "$0" uninstall-daemon >/dev/null 2>&1 || true
    fi
    if [ -d "$MINSKY_STATE_DIR" ]; then
      rm -rf "$MINSKY_STATE_DIR"
    fi
    echo "✅ minsky uninstalled"
    echo "   - launchd plist removed"
    echo "   - $MINSKY_STATE_DIR removed"
    echo "   - daemon stopped"
    echo ""
    echo "Note: host repo data (.minsky/ inside your repos) is untouched."
    exit 0
    ;;
  consent)
    # `minsky consent --yes | --no` — record telemetry consent atomically.
    #
    # Slice (2) of P0 `agent-mediated-install` per INSTALL.md Step 5.
    # Collapses the 10-line shell snippet (salt gen, sha256, atomic
    # write) into one CLI invocation that all agents (claude-code /
    # devin / cursor) handle identically. The bin shim parses + dispatches
    # to an inline node script so this stays zero-dep at the install
    # layer.
    #
    # Behavior:
    #   - `--yes`  → records consent: true
    #   - `--no`   → records consent: false
    #   - both / neither → exits 2 with "ambiguous"
    #   - idempotent (re-run with same value is a no-op rewrite)
    #   - writes ~/.minsky/telemetry-consent.json atomically (tmp + rename)
    #   - hashes $PWD as `host_path_hash` using ~/.minsky/machine-salt
    #     (created on first run, 32 random bytes base64) so the server
    #     never sees the raw path
    #   - POSTs to MINSKY_TELEMETRY_ENDPOINT when set (best-effort;
    #     never blocks the install)
    #
    # Source: M1 milestone `minsky-consent-subcommand` (P1 sub-task of
    # parent `agent-mediated-install`); RFC 8615 (canonical-path
    # convention for agent-discoverable metadata).
    _yes=0
    _no=0
    for _a in "$@"; do
      case "$_a" in
        --yes) _yes=1 ;;
        --no)  _no=1 ;;
      esac
    done
    if [ "$_yes" = "1" ] && [ "$_no" = "1" ]; then
      echo "minsky consent: --yes and --no are mutually exclusive" >&2
      exit 2
    fi
    if [ "$_yes" = "0" ] && [ "$_no" = "0" ]; then
      echo "minsky consent: pass --yes or --no" >&2
      exit 2
    fi
    _consent="false"
    [ "$_yes" = "1" ] && _consent="true"
    MINSKY_CONSENT_VALUE="$_consent" \
    MINSKY_STATE_DIR="$MINSKY_STATE_DIR" \
    MINSKY_TELEMETRY_ENDPOINT="${MINSKY_TELEMETRY_ENDPOINT:-}" \
    MINSKY_AGENT="${MINSKY_AGENT:-${MINSKY_LLM_PROVIDER:-claude}}" \
    MINSKY_HOST_PATH="$(pwd)" \
    node --input-type=module -e "
import { mkdirSync, readFileSync, writeFileSync, existsSync, renameSync } from 'node:fs';
import { createHash, randomBytes } from 'node:crypto';
import { join } from 'node:path';

const stateDir = process.env.MINSKY_STATE_DIR;
const consent = process.env.MINSKY_CONSENT_VALUE === 'true';
const endpoint = process.env.MINSKY_TELEMETRY_ENDPOINT;
const agent = process.env.MINSKY_AGENT;
const hostPath = process.env.MINSKY_HOST_PATH;

mkdirSync(stateDir, { recursive: true });

const saltPath = join(stateDir, 'machine-salt');
let salt;
if (existsSync(saltPath)) {
  salt = readFileSync(saltPath, 'utf8').trim();
} else {
  salt = randomBytes(32).toString('base64');
  writeFileSync(saltPath, salt + '\n', { mode: 0o600 });
}

const hash = createHash('sha256').update(salt + hostPath).digest('hex');
const timestamp = new Date().toISOString();
const payload = {
  consent,
  timestamp,
  host_path_hash: hash,
  agent,
};

const target = join(stateDir, 'telemetry-consent.json');
const tmp = target + '.tmp-' + process.pid;
writeFileSync(tmp, JSON.stringify(payload, null, 2) + '\n', { mode: 0o600 });
renameSync(tmp, target);

if (endpoint) {
  try {
    const ctrl = new AbortController();
    const t = setTimeout(() => ctrl.abort(), 3000);
    const resp = await fetch(endpoint, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify(payload),
      signal: ctrl.signal,
    });
    clearTimeout(t);
    if (!resp.ok) {
      console.error('minsky consent: telemetry POST returned status ' + resp.status + ' (consent recorded locally)');
    }
  } catch (err) {
    console.error('minsky consent: telemetry POST failed (consent recorded locally): ' + (err?.message ?? err));
  }
}

console.log('minsky consent: recorded ' + (consent ? 'yes' : 'no') + ' at ' + timestamp);
"
    exit $?
    ;;
  trend|recommend|knowledge)
    # `minsky trend|recommend|knowledge [args...]` — MAPE-K
    # Analyse/Plan/Knowledge consumers of the per-host
    # `.minsky/transform-runs.jsonl` ledger. Each subcommand wraps
    # the matching `scripts/transform_<name>.py` script with $PWD
    # (or --hosts-dir for knowledge) as the default target. Operators
    # type `minsky trend` instead of remembering the python3-script
    # invocation path.
    #
    # See:
    #   - scripts/transform_trend.py     (PR #825, Analyse phase)
    #   - scripts/transform_recommend.py (PR #826, Plan phase)
    #   - scripts/transform_knowledge.py (PR #827, K phase)
    #
    # Each python script auto-detects its target — `trend` and
    # `recommend` default to $PWD; `knowledge` requires `--hosts-dir`
    # (cross-host aggregation has no "current host" default).
    _subcmd="$1"
    shift
    _script_dir="$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")"
    _python_script="$_script_dir/../scripts/transform_${_subcmd}.py"
    if [ ! -f "$_python_script" ]; then
      echo "minsky $_subcmd: script not found at $_python_script" >&2
      echo "  this usually means MINSKY_REPO is misconfigured. Run \`minsky doctor\`." >&2
      exit 1
    fi
    # `knowledge` doesn't take --repo; the rest default --repo to $PWD
    # if the operator didn't pass one.
    if [ "$_subcmd" = "knowledge" ]; then
      exec python3 "$_python_script" "$@"
    fi
    _has_repo=0
    for _a in "$@"; do
      [ "$_a" = "--repo" ] && _has_repo=1
    done
    if [ "$_has_repo" = "1" ]; then
      exec python3 "$_python_script" "$@"
    else
      exec python3 "$_python_script" --repo "$PWD" "$@"
    fi
    ;;
  doctor)
    # `minsky doctor [--quiet]` — health probe for this machine.
    #
    # Checks (each prints PASS / WARN / FAIL):
    #   PASS  node       — node 20+ on PATH
    #   PASS  git        — git on PATH
    #   PASS  gh         — gh CLI installed (optional but recommended)
    #   WARN  config     — ~/.minsky/config.json exists (optional)
    #   PASS  daemon     — daemon running (optional but informative)
    #   WARN  agents     — at least one of devin/claude/aider on PATH
    #   PASS  host       — default_host (if configured) is a git repo
    #
    # Exit codes:
    #   0 — all critical checks (node, git) pass
    #   1 — at least one critical check failed
    #
    # Distinct from `setup.sh --doctor` which probes adapter selfTests
    # against `.minsky/state.json` (the framework substrate). `minsky
    # doctor` is the operator-facing health check: "is this machine
    # ready to run minsky".
    #
    # Source: M1 milestone exit criterion §13 (self-heal).
    _crit_fail=0
    _quiet=0
    for _a in "$@"; do
      [ "$_a" = "--quiet" ] && _quiet=1
    done

    _doctor_print() {
      # _doctor_print STATUS NAME MESSAGE
      # STATUS: PASS | WARN | FAIL
      [ "$_quiet" = "1" ] && [ "$1" = "PASS" ] && return 0
      printf "  %-4s  %-12s %s\n" "$1" "$2" "$3"
    }

    [ "$_quiet" = "0" ] && echo "minsky doctor — checking host machine readiness" && echo ""

    # CRITICAL — node 20+
    if command -v node >/dev/null 2>&1; then
      _v=$(node --version 2>/dev/null | sed 's/^v//')
      _major=$(echo "$_v" | cut -d. -f1)
      if [ "$_major" -ge 20 ] 2>/dev/null; then
        _doctor_print PASS "node" "$_v"
      else
        _doctor_print FAIL "node" "$_v (need 20+)"
        _crit_fail=1
      fi
    else
      _doctor_print FAIL "node" "not on PATH"
      _crit_fail=1
    fi

    # CRITICAL — git
    if command -v git >/dev/null 2>&1; then
      _doctor_print PASS "git" "$(git --version 2>/dev/null | head -1)"
    else
      _doctor_print FAIL "git" "not on PATH"
      _crit_fail=1
    fi

    # OPTIONAL — gh
    if command -v gh >/dev/null 2>&1; then
      _doctor_print PASS "gh" "$(gh --version 2>/dev/null | head -1)"
    else
      _doctor_print WARN "gh" "not on PATH (PR creation will be skipped)"
    fi

    # OPTIONAL — config
    _cfg="$MINSKY_STATE_DIR/config.json"
    if [ -f "$_cfg" ]; then
      _host=$(_minsky_config_value "default_host" "$_cfg")
      if [ -n "$_host" ]; then
        _doctor_print PASS "config" "$_cfg (default_host=$_host)"
      else
        _doctor_print WARN "config" "$_cfg exists but default_host is empty"
      fi
    else
      _doctor_print WARN "config" "not found (run: minsky init)"
    fi

    # OPTIONAL — daemon running
    if [ -f "$MINSKY_DAEMON_PID" ]; then
      _pid=$(cat "$MINSKY_DAEMON_PID" 2>/dev/null)
      if kill -0 "$_pid" 2>/dev/null; then
        _doctor_print PASS "daemon" "running (PID $_pid)"
      else
        _doctor_print WARN "daemon" "stale PID file"
      fi
    else
      _doctor_print WARN "daemon" "not running (run: minsky)"
    fi

    # OPTIONAL — at least one agent
    _agent_count=0
    _agent_list=""
    for _agent in devin claude aider codex; do
      if command -v "$_agent" >/dev/null 2>&1; then
        _agent_count=$((_agent_count + 1))
        _agent_list="$_agent_list $_agent"
      fi
    done
    if [ "$_agent_count" -ge 1 ]; then
      _doctor_print PASS "agents" "$_agent_count installed:$_agent_list"
    else
      _doctor_print WARN "agents" "no agents on PATH (devin / claude / aider / codex)"
    fi

    # OPTIONAL — default_host is a git repo
    if [ -n "${_host:-}" ]; then
      if [ -d "$_host/.git" ]; then
        _doctor_print PASS "host" "$_host (valid git repo)"
      else
        _doctor_print WARN "host" "$_host is not a git repo"
      fi
    fi

    # Fold bash-skeleton probes into doctor (rule #16 CLI consolidation
    # corollary, 2026-05-25): `minsky doctor` is the single health-
    # check surface.
    #
    # Conditional: only run the bash-skeleton fold when there's
    # evidence the operator cares about the Path A bash path. Signals:
    #   (a) `.minsky/repo.yaml` in $PWD — operator is in a bootstrapped
    #       host (about to run `minsky --transform`).
    #   (b) `bin/minsky-run.sh` in the repo dir AND the operator is
    #       INSIDE the minsky repo itself — they're developing the
    #       bash path.
    # Without one of these signals, the bash-skeleton probes are
    # likely noise (e.g. running `minsky doctor` in a directory that
    # has nothing to do with minsky). Also skipping it keeps doctor
    # FAST when called as the no-args preamble — the bash-skeleton
    # probes shell out to shellcheck, python3 compile, etc. which add
    # ~5s per call. The integration test in m1-red-green.test.ts spawns
    # `minsky doctor` with a 30s timeout from a clean tmpdir; without
    # the conditional, the spawn ETIMEDOUTs on slow CI runners.
    # Trigger conditional: only run the bash-skeleton fold when the
    # operator is INSIDE a bootstrapped host (`.minsky/repo.yaml`
    # present in $PWD). This is the only signal that the operator is
    # about to run `minsky --transform` or otherwise needs the bash
    # path validated.
    #
    # Why not also fold when in the minsky repo itself? Because the
    # bash-skeleton fold calls `python3` via `bash-doctor-probes.sh`,
    # and corporate Python wrappers (Intuit dotfiles, etc.) take 30+
    # seconds to bootstrap uv with a fresh HOME — turning `doctor`
    # into a 30-90s command when invoked from a fresh-HOME test env
    # (e.g. the m1-red-green.test.ts integration suite). The existing
    # comment at the top of this file explicitly warns about this
    # ("bin/minsky uses portable shell helpers, not python3"). The
    # conditional defers that cost until the operator is in a context
    # where it actually matters (a bootstrapped host).
    #
    # Operator escape: pass `--all` (or `--smoke`) to force the fold
    # regardless of $PWD signals.
    _bd_should_run=0
    if [ -f "$PWD/.minsky/repo.yaml" ]; then
      _bd_should_run=1
    fi
    # Always run when --smoke or --all is passed (explicit operator
    # request for the full check).
    for _a in "$@"; do
      case "$_a" in
        --smoke|--all) _bd_should_run=1 ;;
      esac
    done

    if [ "$_bd_should_run" = "1" ]; then
      [ "$_quiet" = "0" ] && echo "" && echo "--- bash-skeleton probes (Path A) — informational ---"
      _bd_probe_args=()
      [ "$_quiet" = "1" ] && _bd_probe_args+=("--quiet")
      for _a in "$@"; do
        [ "$_a" = "--smoke" ] && _bd_probe_args+=("--smoke")
      done
      # Direct function call — no subshell, no second front door (rule
      # #16 CLI-consolidation corollary, 2026-05-25 follow-up). The
      # function sets `_bd_skeleton_crit_fail` globally; we read it but
      # do NOT propagate into `_crit_fail` because `doctor`'s invariant
      # is "the machine can run AT LEAST ONE Minsky path" — TS-substrate
      # critical checks gate exit code; bash-skeleton fails are
      # informational. This matches the integration test pin in
      # test/integration/m1-red-green.test.ts § "minsky doctor exits 0
      # when no critical checks fail".
      # `|| true` because the function returns non-zero on bash-skeleton
      # crit-fail (so the deprecated `bash-doctor` alias can preserve
      # strict semantics), and we have `set -e` at the top of bin/minsky.
      _run_bash_skeleton_probes "${_bd_probe_args[@]:-}" || true
      if [ "${_bd_skeleton_crit_fail:-0}" != "0" ] && [ "$_quiet" = "0" ]; then
        echo "(bash-skeleton has critical fails — see above; operator must fix before \`minsky --transform\`)"
      fi
    elif [ "$_quiet" = "0" ]; then
      echo ""
      echo "(bash-skeleton probes skipped: no .minsky/repo.yaml in \$PWD; run \`minsky doctor --all\` to force)"
    fi

    [ "$_quiet" = "0" ] && echo ""
    if [ "$_crit_fail" = "0" ]; then
      [ "$_quiet" = "0" ] && echo "✅ doctor: ready"
      exit 0
    else
      echo "❌ doctor: critical checks failed — minsky cannot run on this machine until they pass"
      exit 1
    fi
    ;;
  bash-doctor)
    # DEPRECATED alias for `minsky doctor --all` (rule #16 CLI-
    # consolidation corollary, 2026-05-25). The probe body lives once
    # in `_run_bash_skeleton_probes` (top of file). Direct invocation
    # is preserved for PR-#866-era operator habits + test backwards
    # compat; will be removed in the next major version.
    # <!-- @deprecated 2026-05-25 — folded into `minsky doctor` -->
    #
    # Direct semantics differ from `doctor --all` in ONE way:
    # `bash-doctor` exits 1 when bash-skeleton has critical fails
    # (strict mode — script callers may rely on this). `doctor --all`
    # exits 0 even when bash-skeleton fails (informational, per
    # doctor's "at least one path works" invariant).
    [ "${MINSKY_DOCTOR_FOLD:-0}" != "1" ] && \
      echo "minsky bash-doctor: DEPRECATED — use \`minsky doctor --all\` (single front door). bash-doctor will be removed in the next major version." >&2

    # Print header for direct callers (consistent with old behavior).
    _bd_alias_quiet=0
    for _a in "$@"; do
      [ "$_a" = "--quiet" ] && _bd_alias_quiet=1
    done
    [ "$_bd_alias_quiet" = "0" ] && echo "minsky bash-doctor — pre-flight for Path A bash + Python skeleton" && echo ""

    # Single body — shared with `doctor`. Exit code reflects strict
    # bash-skeleton semantics (the only behavioral delta vs `doctor`).
    # `|| true` because we want to read $_bd_skeleton_crit_fail below
    # before script-wide errexit aborts us.
    _run_bash_skeleton_probes "$@" || true

    [ "$_bd_alias_quiet" = "0" ] && echo ""
    if [ "${_bd_skeleton_crit_fail:-0}" = "0" ]; then
      [ "$_bd_alias_quiet" = "0" ] && echo "✅ bash-doctor: bash + Python skeleton is ready for \`minsky --transform\`"
      exit 0
    else
      echo "❌ bash-doctor: critical checks failed — \`minsky --transform\` will fail until the above are fixed"
      exit 1
    fi
    ;;
  iter-once)
    # `minsky iter-once <host-dir> [--live] [--no-capture]` — run
    # EXACTLY ONE iteration of the bash skeleton against <host-dir>,
    # tee'ing all I/O to <host-dir>/.minsky/iter-once.log so the
    # operator can `cat` it without re-running.
    #
    # Default mode is `--dry-run` (no agent spawn, just plan+record).
    # That's the safe default for the operator's tight-loop "did my
    # change to bin/minsky-run.sh do what I expected?" workflow —
    # zero LLM tokens, zero risk of side effects on the host's
    # branches.
    #
    # `--live` flips to a real spawn — burns tokens, can push commits +
    # open PRs against the host. Always pair with `bash-doctor` first.
    #
    # On exit, prints a one-line summary: verdict + ledger path +
    # failure-capture path (if any). The operator's mental model is:
    #
    #   minsky bash-doctor    # is this machine healthy?
    #   minsky iter-once foo  # try one dry iteration
    #   minsky iter-once foo --live  # if dry was good, try a real one
    #   minsky tail-failures foo  # if something broke, what was it?
    #
    # Source: 2026-05-25 retro slice 3 — operator-facing "quick iterate"
    # surface; rule #1 (don't reinvent — wraps bin/minsky-run.sh's
    # existing --max-iterations=1 path, no new agent code); rule #4
    # (everything measurable, everything visible — the iter-once log is
    # the visible surface).
    HOST_DIR=""
    ITER_ONCE_LIVE=0
    ITER_ONCE_NO_CAPTURE=0
    shift  # consume `iter-once`
    while [ $# -gt 0 ]; do
      case "$1" in
        --live) ITER_ONCE_LIVE=1; shift ;;
        --no-capture) ITER_ONCE_NO_CAPTURE=1; shift ;;
        -h|--help)
          cat <<'IUSAGE'
Usage:
  minsky iter-once <host-dir> [--live] [--no-capture]

Options:
  --live          Spawn the agent for real (default: --dry-run, no spawn)
  --no-capture    Disable failure-capture for this iteration (sets
                  MINSKY_CAPTURE_FAILURES=0)
  -h, --help      Print this help

Output: <host-dir>/.minsky/iter-once.log — full stdout+stderr of the
iteration; survives across runs (appended).

After exit, the summary line names:
  - the verdict from the JSONL ledger row
  - the ledger path: <host-dir>/.minsky/experiment-store/cross-repo/<task-id>.jsonl
  - the failure-capture path: <host-dir>/.minsky/failures/<latest>/
    (only if the verdict was non-validated AND capture was on)
IUSAGE
          exit 0
          ;;
        --*) echo "iter-once: unknown flag: $1" >&2; exit 2 ;;
        *)
          if [ -z "$HOST_DIR" ]; then
            HOST_DIR="$1"; shift
          else
            echo "iter-once: unexpected arg: $1" >&2; exit 2
          fi
          ;;
      esac
    done
    if [ -z "$HOST_DIR" ]; then
      echo "iter-once: host-dir required" >&2
      echo "  usage: minsky iter-once <host-dir> [--live] [--no-capture]" >&2
      exit 2
    fi
    if [ ! -d "$HOST_DIR" ]; then
      echo "iter-once: host-dir not found: $HOST_DIR" >&2
      exit 1
    fi
    # Absolute path so the parent-dir resolution below is unambiguous.
    HOST_DIR="$(cd "$HOST_DIR" && pwd)"
    HOSTS_PARENT="$(dirname "$HOST_DIR")"
    _real_bin=$(_minsky_realpath "$0")
    _repo_dir=$(dirname "$(dirname "$_real_bin")")
    RUNNER="$_repo_dir/bin/minsky-run.sh"
    if [ ! -x "$RUNNER" ]; then
      echo "iter-once: $RUNNER not executable (run: chmod +x $RUNNER)" >&2
      exit 1
    fi
    # Iter log lives inside the host's .minsky/ — survives the
    # iteration's own mktemp cleanup.
    mkdir -p "$HOST_DIR/.minsky"
    ITER_LOG="$HOST_DIR/.minsky/iter-once.log"
    {
      echo ""
      echo "=== minsky iter-once @ $(date -u +%Y-%m-%dT%H:%M:%S.000Z) ==="
      echo "host:        $HOST_DIR"
      echo "mode:        $([ "$ITER_ONCE_LIVE" = "1" ] && echo "LIVE (agent will spawn)" || echo "dry-run (no agent spawn)")"
      echo "capture:     $([ "$ITER_ONCE_NO_CAPTURE" = "1" ] && echo "OFF" || echo "on")"
      echo "---"
    } >> "$ITER_LOG"

    # Dispatch. --max-iterations 1 + --iterations-per-host 1 guarantees
    # exactly one iteration even if more hosts share the parent.
    RUNNER_ARGS=(--hosts-dir "$HOSTS_PARENT" --max-iterations 1 --iterations-per-host 1)
    if [ "$ITER_ONCE_LIVE" != "1" ]; then
      RUNNER_ARGS+=(--dry-run)
    fi
    if [ "$ITER_ONCE_NO_CAPTURE" = "1" ]; then
      export MINSKY_CAPTURE_FAILURES=0
    fi

    echo "iter-once: running $RUNNER ${RUNNER_ARGS[*]}" >&2
    set +e
    bash "$RUNNER" "${RUNNER_ARGS[@]}" 2>&1 | tee -a "$ITER_LOG"
    RUN_EXIT=${PIPESTATUS[0]}
    set -e

    # Summarize: find the JSONL row this iteration wrote (most recent
    # file under cross-repo/) and the failure-capture (if any).
    LEDGER_DIR="$HOST_DIR/.minsky/experiment-store/cross-repo"
    LATEST_LEDGER=""
    if [ -d "$LEDGER_DIR" ]; then
      LATEST_LEDGER=$(/usr/bin/find "$LEDGER_DIR" -maxdepth 1 -type f -name '*.jsonl' -print0 2>/dev/null \
        | xargs -0 ls -t 2>/dev/null \
        | head -1 || true)
    fi
    LATEST_VERDICT="(unknown)"
    LATEST_NOTES=""
    LATEST_PR_URL=""
    if [ -n "$LATEST_LEDGER" ] && [ -f "$LATEST_LEDGER" ]; then
      LATEST_VERDICT=$(tail -1 "$LATEST_LEDGER" | jq -r '.verdict // "(no-verdict-field)"' 2>/dev/null || echo "(parse-error)")
      LATEST_NOTES=$(tail -1 "$LATEST_LEDGER" | jq -r '.notes // ""' 2>/dev/null || echo "")
      LATEST_PR_URL=$(tail -1 "$LATEST_LEDGER" | jq -r '.pr_url // ""' 2>/dev/null || echo "")
    fi
    LATEST_FAILURE_DIR=""
    LATEST_DURATION_MS=""
    if [ -d "$HOST_DIR/.minsky/failures" ]; then
      LATEST_FAILURE_DIR=$(/usr/bin/find "$HOST_DIR/.minsky/failures" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null \
        | xargs -0 ls -dt 2>/dev/null \
        | head -1 || true)
      if [ -n "$LATEST_FAILURE_DIR" ] && [ -f "$LATEST_FAILURE_DIR/metadata.json" ]; then
        LATEST_DURATION_MS=$(jq -r '.duration_ms // ""' "$LATEST_FAILURE_DIR/metadata.json" 2>/dev/null || echo "")
      fi
    fi

    echo ""
    echo "=== iter-once summary ==="
    echo "  verdict:        $LATEST_VERDICT"
    if [ -n "$LATEST_DURATION_MS" ] && [ "$LATEST_DURATION_MS" != "0" ] && [ "$LATEST_DURATION_MS" != "null" ]; then
      echo "  spawn duration: ${LATEST_DURATION_MS}ms"
    fi
    if [ -n "$LATEST_NOTES" ] && [ "$LATEST_NOTES" != "null" ]; then
      # Truncate notes to 120 chars so the summary stays scannable
      _notes_short=$(printf '%s' "$LATEST_NOTES" | head -c 120)
      [ "${#LATEST_NOTES}" -gt 120 ] && _notes_short="${_notes_short}..."
      echo "  notes:          $_notes_short"
    fi
    if [ -n "$LATEST_PR_URL" ] && [ "$LATEST_PR_URL" != "null" ] && [ "$LATEST_PR_URL" != "" ]; then
      echo "  pr url:         $LATEST_PR_URL"
    fi
    echo "  ledger row:     ${LATEST_LEDGER:-(none)}"
    echo "  iter log:       $ITER_LOG"
    if [ -n "$LATEST_FAILURE_DIR" ] && [ "$LATEST_VERDICT" != "validated" ] && [ "$LATEST_VERDICT" != "planned" ]; then
      echo "  failure capture: $LATEST_FAILURE_DIR"
      echo "                   (cat $LATEST_FAILURE_DIR/metadata.json | jq .)"
      echo "                   (minsky tail-failures $HOST_DIR --latest)"
    fi
    exit "$RUN_EXIT"
    ;;
  tail-failures)
    # `minsky tail-failures [host-dir] [--count N] [--latest]` — show
    # the most recent failure-capture dirs (from PR #866's failure-
    # capture pattern) for a host.
    #
    # Without args, defaults to $PWD as the host.
    # Default --count is 5 (most recent 5 capture dirs).
    # --latest is a shortcut for --count 1 + cat metadata.json + show
    #   the brief + tail of stdout.log; the operator's "show me what
    #   broke last" one-liner.
    #
    # Source: 2026-05-25 retro slice 4 — operator-facing "quick detect"
    # surface; rule #4 (everything measurable, everything visible).
    HOST_DIR=""
    TAIL_COUNT=5
    TAIL_LATEST=0
    shift  # consume `tail-failures`
    while [ $# -gt 0 ]; do
      case "$1" in
        --count)
          [ $# -ge 2 ] || { echo "--count requires a value" >&2; exit 2; }
          TAIL_COUNT="$2"; shift 2 ;;
        --latest) TAIL_LATEST=1; shift ;;
        -h|--help)
          cat <<'TUSAGE'
Usage:
  minsky tail-failures [host-dir] [--count N] [--latest]

Default host-dir is $PWD. Default --count is 5.

  --count N       Show the N most recent capture dirs (default 5)
  --latest        Shortcut: show JUST the most recent capture dir's
                  metadata.json + brief.md (head) + stdout.log (tail).
                  Operator's "show me what broke last" one-liner.

Reads <host-dir>/.minsky/failures/*/ written by the failure-capture
pattern (PR #866). If the dir is empty or missing, prints a friendly
message and exits 0.
TUSAGE
          exit 0
          ;;
        --*) echo "tail-failures: unknown flag: $1" >&2; exit 2 ;;
        *)
          if [ -z "$HOST_DIR" ]; then
            HOST_DIR="$1"; shift
          else
            echo "tail-failures: unexpected arg: $1" >&2; exit 2
          fi
          ;;
      esac
    done
    [ -z "$HOST_DIR" ] && HOST_DIR="$PWD"
    if [ ! -d "$HOST_DIR" ]; then
      echo "tail-failures: host-dir not found: $HOST_DIR" >&2
      exit 1
    fi
    HOST_DIR="$(cd "$HOST_DIR" && pwd)"
    FAILURES_DIR="$HOST_DIR/.minsky/failures"
    if [ ! -d "$FAILURES_DIR" ]; then
      echo "tail-failures: no failure-capture dir at $FAILURES_DIR"
      echo "  (no iterations have failed on this host, or capture is disabled via MINSKY_CAPTURE_FAILURES=0)"
      exit 0
    fi
    # Sort by mtime desc.
    CAPTURE_DIRS=$(/usr/bin/find "$FAILURES_DIR" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null \
      | xargs -0 ls -dt 2>/dev/null || true)
    if [ -z "$CAPTURE_DIRS" ]; then
      echo "tail-failures: $FAILURES_DIR exists but is empty"
      exit 0
    fi
    if [ "$TAIL_LATEST" = "1" ]; then
      LATEST=$(echo "$CAPTURE_DIRS" | head -1)
      echo "=== latest failure capture: $LATEST ==="
      echo ""
      if [ -f "$LATEST/metadata.json" ]; then
        echo "--- metadata.json ---"
        if command -v jq >/dev/null 2>&1; then
          jq . "$LATEST/metadata.json"
        else
          cat "$LATEST/metadata.json"
        fi
        echo ""
      fi
      if [ -f "$LATEST/brief.md" ]; then
        echo "--- brief.md (first 30 lines) ---"
        head -30 "$LATEST/brief.md"
        echo ""
      fi
      if [ -f "$LATEST/stdout.log" ]; then
        echo "--- stdout.log (last 50 lines) ---"
        tail -50 "$LATEST/stdout.log"
        echo ""
      fi
      echo "(full artifacts at $LATEST/)"
      exit 0
    fi
    # Default: list up to TAIL_COUNT dirs with a one-line summary each.
    echo "=== last $TAIL_COUNT failure captures on $HOST_DIR ==="
    echo "$CAPTURE_DIRS" | head -"$TAIL_COUNT" | while read -r dir; do
      [ -z "$dir" ] && continue
      verdict=""
      duration=""
      task_id=""
      if [ -f "$dir/metadata.json" ] && command -v jq >/dev/null 2>&1; then
        verdict=$(jq -r '.verdict // "?"' "$dir/metadata.json" 2>/dev/null)
        duration=$(jq -r '.duration_ms // "?"' "$dir/metadata.json" 2>/dev/null)
        task_id=$(jq -r '.task_id // "?"' "$dir/metadata.json" 2>/dev/null)
      fi
      printf "  %-60s  verdict=%s  task=%s  duration_ms=%s\n" "$(basename "$dir")" "$verdict" "$task_id" "$duration"
    done
    echo ""
    echo "(deep-dive: minsky tail-failures $HOST_DIR --latest)"
    exit 0
    ;;
  report)
    # `minsky report [--baseline | --delta] [--repo <path>]` — print
    # the latest metric snapshot, the diff against the previous, or
    # a human-readable summary. Delegates to scripts/minsky-report.mjs
    # which holds the pure formatting logic (covered by paired unit
    # tests in scripts/minsky-report.test.mjs).
    #
    # Source: M1 milestone exit criterion §7.
    _real_bin=$(_minsky_realpath "$0")
    _repo_dir=$(dirname "$(dirname "$_real_bin")")
    shift  # consume `report`, forward remaining args
    exec node "$_repo_dir/scripts/minsky-report.mjs" "$@"
    ;;
  benchmark)
    # `minsky benchmark [--iterations N] [--host PATH] [--no-live] [--json]`
    # Run N iterations of the cross-repo runner and report verdict
    # distribution + pass-rate + mean duration. Pure helpers (verdict
    # classification, output parsing, aggregation) live in scripts/
    # minsky-benchmark.mjs and are covered by paired unit tests.
    #
    # Source: M1 milestone exit criterion §10.
    _real_bin=$(_minsky_realpath "$0")
    _repo_dir=$(dirname "$(dirname "$_real_bin")")
    shift  # consume `benchmark`, forward remaining args
    exec node "$_repo_dir/scripts/minsky-benchmark.mjs" "$@"
    ;;
  competitive)
    # `minsky competitive [--host PATH] [--write-to PATH] [--json]`
    # Build the M1.10 competitive scorecard. Reads the host's
    # `.minsky/orchestrate.jsonl`, computes Minsky's metrics via
    # @minsky/competitive-benchmark, joins them against the published
    # competitor corpus (competitors/*.md → src/competitors.ts), and
    # writes `competitive-scorecard.json`. Pure builder lives in
    # `novel/competitive-benchmark/` with paired unit tests.
    #
    # Two-part acceptance (rule #9 pre-registered HDD):
    #   1. Shape — ≥4 competitors × ≥5 metrics with published data
    #   2. Live deltas — ≥1 Minsky-measured metric (cold-start gate)
    #
    # Exit 0 only when both hold; 1 when either gate is open.
    # Source: M1.10 (docs/plans/self-metrics-competitive-benchmark.md).
    _real_bin=$(_minsky_realpath "$0")
    _repo_dir=$(dirname "$(dirname "$_real_bin")")
    shift  # consume `competitive`, forward remaining args
    exec node "$_repo_dir/scripts/benchmark-run.mjs" "$@"
    ;;
  install-daemon)
    # Install a launchd plist so minsky auto-starts on login/reboot.
    # Reads default_host from ~/.minsky/config.json.
    _real_bin=$(_minsky_realpath "$0")
    _default_host=$(_minsky_config_value "default_host")
    if [ -z "$_default_host" ]; then
      _default_host="${2:-$(pwd)}"
      echo "No default_host in ~/.minsky/config.json — using: $_default_host"
    fi

    _plist="$HOME/Library/LaunchAgents/com.minsky.daemon.plist"
    # Resolve the node binary and runner script — launchd runs the node
    # process DIRECTLY (foreground), not via --daemon which backgrounds.
    _repo_dir=$(dirname "$(dirname "$_real_bin")")
    # Resolve a STABLE node path — fnm's multishell paths are ephemeral
    # (change every terminal session). Use the fnm alias or homebrew path.
    if [ -x "$HOME/.fnm/aliases/default/bin/node" ]; then
      _node_bin="$HOME/.fnm/aliases/default/bin/node"
    elif _fnm_node=$(ls "$HOME/.local/share/fnm/node-versions"/v2*/installation/bin/node 2>/dev/null | sort -V | tail -1) && [ -x "$_fnm_node" ]; then
      _node_bin="$_fnm_node"
    elif [ -x "/opt/homebrew/bin/node" ]; then
      _node_bin="/opt/homebrew/bin/node"
    elif [ -x "/usr/local/bin/node" ]; then
      _node_bin="/usr/local/bin/node"
    else
      _node_bin=$(which node)
    fi
    _runner="$_repo_dir/novel/cross-repo-runner/bin/minsky-run.mjs"
    # Phase 7b'-prep: when MINSKY_INSTALL_DAEMON_BASH=1, generate a
    # plist that invokes the Path A bash port (#797-#803) instead of
    # the Node runner. Same supervisor semantics; one-line ProgramArguments
    # switch. Operator opt-in:
    #   MINSKY_INSTALL_DAEMON_BASH=1 minsky install-daemon
    # The default (env unset / =0) keeps the Node runner so a casual
    # `git pull` doesn't silently flip the runner under the operator.
    if [ "${MINSKY_INSTALL_DAEMON_BASH:-0}" = "1" ]; then
      _bash_runner="$_repo_dir/bin/minsky-run.sh"
      if [ ! -x "$_bash_runner" ]; then
        echo "minsky: MINSKY_INSTALL_DAEMON_BASH=1 but $_bash_runner not executable" >&2
        exit 1
      fi
      # ProgramArguments for the bash variant: invoke bash directly so
      # launchd sees the bash PID and KeepAlive=true reaches it. The
      # bash runner takes --hosts-dir; we pass the host's parent so
      # the walker finds exactly one host (matches run-daemon.sh's
      # single-host adaptation).
      _bash_hosts_parent=$(dirname "$_default_host")
      _program_args="    <string>/bin/bash</string>
    <string>$_bash_runner</string>
    <string>--hosts-dir</string>
    <string>$_bash_hosts_parent</string>"
    else
      _program_args="    <string>$_node_bin</string>
    <string>$_runner</string>
    <string>--host</string>
    <string>$_default_host</string>
    <string>--loop</string>"
    fi
    # Propagate agent-auth env vars from the operator's current shell
    # so the daemon child inherits them via launchd's `EnvironmentVariables`.
    # Without this, devin/claude/openai/anthropic CLIs spawn under launchd
    # with EMPTY auth, exit non-zero (often signal-killed), and surface
    # as `verdict=spawn-failed exit=-1 stderr=(empty)` — the entire
    # `spawn-failed-exit-minus-one-silent-empty-stderr` P0 (2026-05-19).
    # Iterate over DEVIN_*, CLAUDE_*, OPENAI_*, ANTHROPIC_* and emit
    # one `<key>NAME</key><string>VALUE</string>` pair per var. XML-escape
    # the value (only `&` and `<` need escaping inside a `<string>` literal
    # per the plist DTD) so secrets that contain those characters don't
    # corrupt the plist. Names already pass the `^[A-Z][A-Z0-9_]*$` shape
    # (env-var naming rule), so they need no escaping.
    _xml_env_pairs=""
    while IFS='=' read -r _env_name _env_value; do
      case "$_env_name" in
        DEVIN_*|CLAUDE_*|OPENAI_*|ANTHROPIC_*)
          # XML-escape `&` first (so subsequent `<`/`>` escapes don't
          # double-escape their introduced `&`), then `<` and `>`.
          _env_value_esc=$(printf '%s' "$_env_value" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g')
          _xml_env_pairs="${_xml_env_pairs}
    <key>${_env_name}</key>
    <string>${_env_value_esc}</string>"
          ;;
      esac
    done <<EOF
$(env | grep -E '^(DEVIN_|CLAUDE_|OPENAI_|ANTHROPIC_)' || true)
EOF

    # Generate the new plist content into a tempfile so we can
    # idempotency-check against the existing file before overwriting +
    # reloading launchd. Without this, every `minsky install-daemon`
    # call ran `launchctl bootout` + `bootstrap` even when the plist
    # was unchanged — which kills the running daemon on every call,
    # making the new auto-install-on-pull hook destructive. With this:
    # same content → silent no-op (no kill); different content →
    # overwrite + reload as before. `MINSKY_INSTALL_DAEMON_QUIET=1`
    # suppresses the "already up to date" line for hook callers.
    _plist_tmp="$(mktemp)"
    cat > "$_plist_tmp" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.minsky.daemon</string>
  <key>ProgramArguments</key>
  <array>
$_program_args
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Standard</string>
  <key>StandardOutPath</key>
  <string>$MINSKY_DAEMON_LOG</string>
  <key>StandardErrorPath</key>
  <string>$MINSKY_DAEMON_LOG</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:$HOME/.local/bin:$HOME/.fnm/aliases/default/bin</string>
    <key>HOME</key>
    <string>$HOME</string>
    <key>MINSKY_NON_INTERACTIVE</key>
    <string>1</string>${_xml_env_pairs}
  </dict>
  <key>ThrottleInterval</key>
  <integer>10</integer>
</dict>
</plist>
PLIST_EOF

    # Idempotency: if the existing plist is byte-identical to the
    # newly-generated one, skip the bootout/bootstrap reload — that
    # reload kills the running daemon process, which a no-op call
    # MUST NOT do. `cmp -s` is silent + portable + fast.
    if [ -f "$_plist" ] && cmp -s "$_plist_tmp" "$_plist"; then
      rm -f "$_plist_tmp"
      if [ "${MINSKY_INSTALL_DAEMON_QUIET:-0}" != "1" ]; then
        echo "✅ com.minsky.daemon plist already up to date (no reload)"
        echo "   plist: $_plist"
      fi
      exit 0
    fi
    mv "$_plist_tmp" "$_plist"

    launchctl bootout "gui/$(id -u)/com.minsky.daemon" 2>/dev/null || true
    launchctl bootstrap "gui/$(id -u)" "$_plist"
    echo "✅ Installed com.minsky.daemon"
    echo "   plist: $_plist"
    echo "   host: $_default_host"
    # Count propagated agent-auth env vars (DEVIN_*, CLAUDE_*, OPENAI_*,
    # ANTHROPIC_*) and report them so the operator can spot at install
    # time when the shell didn't have the expected creds — without this
    # line, missing env vars only surface much later as silent
    # `exit=-1 stderr=(empty)` iterations. `spawn-failed-exit-minus-one-
    # silent-empty-stderr` (2026-05-19) makes this visibility iron.
    _propagated_env_count=$(env | grep -E '^(DEVIN_|CLAUDE_|OPENAI_|ANTHROPIC_)' | wc -l | tr -d ' ')
    if [ "$_propagated_env_count" = "0" ]; then
      echo "   ⚠ NO DEVIN_*/CLAUDE_*/OPENAI_*/ANTHROPIC_* env vars in your shell —"
      echo "     daemon spawns may silent-fail. Export them and re-run install-daemon."
    else
      echo "   ✅ propagated $_propagated_env_count agent-auth env vars from shell"
    fi
    echo "   auto-starts on login + restarts on crash"
    echo ""
    echo "   Check: launchctl list | grep minsky.daemon"
    echo "   Remove: minsky uninstall-daemon"
    exit 0
    ;;
  uninstall-daemon)
    _plist="$HOME/Library/LaunchAgents/com.minsky.daemon.plist"
    launchctl bootout "gui/$(id -u)/com.minsky.daemon" 2>/dev/null || true
    rm -f "$_plist"
    echo "✅ Removed com.minsky.daemon"
    echo "   minsky will no longer auto-start on login/reboot"
    exit 0
    ;;
  update)
    # Graceful pause → pull latest → rebuild → restart from same spot.
    # The experiment-store preserves iteration history so the daemon
    # resumes from the next unfinished task after restart.
    echo "minsky update — pause, pull, rebuild, resume"
    echo ""

    # 1. Stop daemon gracefully
    if pgrep -f "cross-repo-runner/bin/minsky-run" >/dev/null 2>&1; then
      echo "  1/4 Stopping daemon..."
      pkill -TERM -f "cross-repo-runner/bin/minsky-run"
      rm -f "$MINSKY_DAEMON_PID"
      sleep 2
      echo "       ✅ Daemon stopped"
    else
      echo "  1/4 No daemon running — skip"
    fi

    # Resolve the real minsky repo dir (follows symlinks)
    _real_bin=$(_minsky_realpath "$0")
    _repo_dir=$(dirname "$(dirname "$_real_bin")")

    # 2. Pull latest
    echo "  2/4 Pulling latest from $_repo_dir..."
    git -C "$_repo_dir" pull --rebase 2>&1 | head -5
    echo "       ✅ Pulled"

    # 3. Rebuild
    echo "  3/4 Rebuilding..."
    (cd "$_repo_dir" && pnpm install 2>&1 | tail -3)
    echo "       ✅ Built"

    # 4. Restart daemon with same host
    # Detect the host from the last daemon's args
    LAST_HOST=$(ps aux 2>/dev/null | grep minsky-run | grep -v grep | grep -oE '\-\-host [^ ]+' | awk '{print $2}' | head -1)
    if [ -z "$LAST_HOST" ]; then
      LAST_HOST="${2:-$(pwd)}"
    fi
    echo "  4/4 Restarting on $LAST_HOST..."
    "$0" --daemon --host "$LAST_HOST"
    echo ""
    echo "✅ Update complete. Daemon resumed from where it left off."
    echo "   Run 'minsky watch' to monitor."
    exit 0
    ;;
  qa)
    # `minsky qa` — open .minsky/qa-log.md in $EDITOR, then tail it.
    #
    # Slice 3 of P0 `minsky-human-comm-via-file`. The operator surface
    # for the agent↔human QA channel established by slices 1+2.
    #
    # Behavior:
    #   - Resolves the log path: $MINSKY_QA_LOG_PATH overrides
    #     "<pwd>/.minsky/qa-log.md" (the convention agents write to).
    #   - Creates the file with a usage-header template when missing so
    #     a fresh operator who runs `minsky qa` first sees the format.
    #   - Opens the file in $EDITOR (fallback: vi). After the editor
    #     exits, `tail -F`'s the file so the operator can watch live
    #     agent additions until Ctrl-C.
    #   - --print-path: emit the resolved path and exit 0 (no editor,
    #     no tail). For scripts / tests / agents that need the path.
    #   - --init-only: ensure the file exists with the header, then
    #     exit 0 (no editor, no tail). For first-run bootstrap.
    #
    # Source: M1 milestone `minsky-human-comm-via-file` slice 3;
    # composes the qa-log-format spec in
    # novel/human-loop/src/qa-log-format.ts (slice 1) and the askHuman
    # async API in novel/human-loop/src/ask-human.ts (slice 2).
    _qa_path="${MINSKY_QA_LOG_PATH:-$(pwd)/.minsky/qa-log.md}"
    _qa_dir="$(dirname "$_qa_path")"
    _init_only=0
    _print_path=0
    for _a in "${@:2}"; do
      case "$_a" in
        --init-only) _init_only=1 ;;
        --print-path) _print_path=1 ;;
        --help|-h)
          echo "Usage: minsky qa [--init-only|--print-path]"
          echo ""
          echo "  Open the agent↔human QA log (.minsky/qa-log.md) in"
          echo "  \$EDITOR, then tail -F it. Override the path with"
          echo "  MINSKY_QA_LOG_PATH."
          exit 0
          ;;
        *)
          echo "minsky qa: unknown flag $_a (try --help)" >&2
          exit 2
          ;;
      esac
    done
    mkdir -p "$_qa_dir"
    if [ ! -f "$_qa_path" ]; then
      cat > "$_qa_path" <<'EOF'
# Minsky QA log

This file is the channel between minsky agents and you. Agents append
question blocks (`## Q:`) and wait up to 4 hours for your answer block
(`## A:`) with the same task-id. The format is documented at
`novel/human-loop/README.md` in the minsky repo.

When you save this file, any agent watching it via `askHuman()` picks
up your answer within 500 ms and resumes work.

You can delete this header at any time — only the `## Q:` / `## A:`
blocks are parsed.

EOF
    fi
    if [ "$_print_path" = "1" ]; then
      echo "$_qa_path"
      exit 0
    fi
    if [ "$_init_only" = "1" ]; then
      echo "minsky qa: log at $_qa_path"
      exit 0
    fi
    _editor="${EDITOR:-vi}"
    "$_editor" "$_qa_path"
    echo "minsky qa: tailing $_qa_path (Ctrl-C to exit)" >&2
    exec tail -F "$_qa_path"
    ;;
  watch)
    # Live dashboard: status + iterations + log in a single refreshing view.
    # Refreshes every 10s. Ctrl-C to exit (daemon keeps running).
    HOST_ARG="${2:-}"
    # Resolve scripts dir for stability-number.mjs
    MINSKY_REPO_SCRIPTS="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)/scripts"
    while true; do
      clear
      _ver=$(git -C "$(dirname "$0")" rev-parse --short HEAD 2>/dev/null || echo "?")
      echo "╔══════════════════════════════════════════════════════════════╗"
      echo "║  minsky watch — $(date '+%H:%M:%S') [$_ver]  Ctrl-C to detach              ║"
      echo "╚══════════════════════════════════════════════════════════════╝"
      echo ""

      # Status
      if [ -f "$MINSKY_DAEMON_PID" ]; then
        daemon_pid=$(cat "$MINSKY_DAEMON_PID" 2>/dev/null)
        if kill -0 "$daemon_pid" 2>/dev/null; then
          uptime=$(ps -p "$daemon_pid" -o etime= 2>/dev/null | tr -d ' ')
          target=$(ps -p "$daemon_pid" -o args= 2>/dev/null | grep -oE '\-\-host [^ ]+' | head -1)
          agent_count=$(pgrep -f 'devin.*--print\|claude.*--print' 2>/dev/null | wc -l | tr -d ' ')
          echo "  🟢 DAEMON  PID=$daemon_pid  uptime=$uptime  agents=$agent_count"
          echo "     target: $target"
        else
          echo "  🔴 DAEMON  stale PID $daemon_pid (not running)"
          echo "     fix: rm -f ~/.minsky/daemon.pid && minsky --daemon --host <repo>"
        fi
      else
        echo "  ⚫ DAEMON  not running"
        echo "     start: minsky --daemon --host <repo>"
      fi
      echo ""

      # Resolve host dir early (needed by stability + iterations + help)
      host_dir="${HOST_ARG:-}"
      if [ -z "$host_dir" ]; then
        # The pipeline returns no matches when no daemon is running; `|| true`
        # absorbs the empty-result exit-1 so `set -euo pipefail` doesn't abort
        # the entire dashboard. Same fix shipped at line 122 for `status`.
        # Discovered 2026-05-20 — fresh-install reader runs `minsky watch`
        # with no daemon, dashboard exits after rendering only the DAEMON
        # line, never gets to show RECENT ITERATIONS or NEEDS HUMAN ACTION.
        host_dir=$(ps aux 2>/dev/null | grep minsky-run | grep -v grep | grep -oE '\-\-host [^ ]+' | awk '{print $2}' | head -1 || true)
      fi
      host_dir="${host_dir:-}"

      # Stability + dynamic timeouts
      if [ -n "$host_dir" ] && command -v node >/dev/null 2>&1; then
        _stab=$(node "$MINSKY_REPO_SCRIPTS/stability-number.mjs" "$host_dir" 2>/dev/null || echo "no data")
        echo "  📈 Stability: $_stab"
        # Stability gate row — per `local-models-stability-gate-90-percent`
        # (M1.1) and user-story 015. Renders one of:
        #   gate: lifted               (≥0.90)
        #   gate: active (78% 7d)      (0.60–0.90)
        #   gate: pivot-eval-needed (52% 7d)  (<0.60)
        #   gate: not-yet-measured     (insufficient data)
        _gate_json=$(node "$MINSKY_REPO_SCRIPTS/measure-stability.mjs" --host-dir="$host_dir" --no-banner-marker 2>/dev/null || echo "")
        if [ -n "$_gate_json" ]; then
          _gate=$(echo "$_gate_json" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{const p=JSON.parse(s);if(p.gate==="not-yet-measured"){process.stdout.write("not-yet-measured")}else{const pct=Math.round((p.rate||0)*100);process.stdout.write(`${p.gate} (${pct}% 7d)`)}}catch{process.stdout.write("")}})' 2>/dev/null || echo "")
          [ -n "$_gate" ] && echo "  🎯 gate: $_gate"
        fi
      fi
      dt_line=$(grep 'dynamic-timeouts' "$MINSKY_DAEMON_LOG" 2>/dev/null | tail -1)
      if [ -n "$dt_line" ]; then
        echo "  ⏱  $dt_line"
      fi

      # Current task (from last experiment yaml write)
      _current_task=$(grep 'wrote.*experiments.*yaml' "$MINSKY_DAEMON_LOG" 2>/dev/null | tail -1 | grep -oE '[a-z][-a-z0-9]*\.yaml' | sed 's/\.yaml//')
      if [ -n "$_current_task" ]; then
        echo "  🔧 Current: $_current_task"
      fi

      # Last iteration summary (from the new ⏱ line)
      _last_iter=$(grep '^⏱ iteration' "$MINSKY_DAEMON_LOG" 2>/dev/null | tail -1)
      if [ -n "$_last_iter" ]; then
        echo "  $_last_iter"
      fi
      echo ""

      # Latest iterations (from experiment store)
      echo "  📊 RECENT ITERATIONS"
      echo "  ────────────────────────────────────────────────────────"
      if [ -n "$host_dir" ] && [ -d "$host_dir/.minsky/experiment-store/cross-repo" ]; then
        for f in "$host_dir"/.minsky/experiment-store/cross-repo/*.jsonl; do
          [ -f "$f" ] || continue
          task=$(basename "$f" .jsonl)
          count=$(wc -l < "$f" | tr -d ' ')
          last=$(tail -1 "$f" 2>/dev/null)
          if [ -n "$last" ]; then
            verdict=$(echo "$last" | grep -o '"verdict":"[^"]*"' | sed 's/"verdict":"//;s/"//')
            ts=$(echo "$last" | grep -o '"ts":"[^"]*"' | sed 's/"ts":"//;s/"//;s/T/ /' | cut -c1-19)
            pr=$(echo "$last" | grep -o '"pr_url":"[^"]*"' | sed 's/"pr_url":"//;s/"//')
            if [ "$pr" = "null" ] || [ -z "$pr" ]; then pr="—"; fi
            printf "  %-42s %s %-12s pr=%s  (%s total)\n" "$task" "$ts" "$verdict" "$pr" "$count"
          fi
        done
      else
        echo "  (no experiment data yet)"
      fi
      echo ""

      # Human help needed
      echo "  🆘 NEEDS HUMAN ACTION"
      echo "  ────────────────────────────────────────────────────────"
      _help_needed=0

      # Check for scope-leak (most recent iteration)
      _last_verdict=""
      if [ -n "$host_dir" ] && [ -d "$host_dir/.minsky/experiment-store/cross-repo" ]; then
        for f in "$host_dir"/.minsky/experiment-store/cross-repo/*.jsonl; do
          [ -f "$f" ] || continue
          v=$(tail -1 "$f" | grep -o '"verdict":"[^"]*"' | sed 's/"verdict":"//;s/"//')
          [ "$v" = "scope-leak" ] && _last_verdict="scope-leak"
        done
      fi
      if [ "$_last_verdict" = "scope-leak" ]; then
        echo "  ⚠️  Last iteration scope-leaked. Commit your changes, then: minsky stop && minsky"
        _help_needed=1
      fi

      # Check for repeated spawn-failed
      if [ -f "$MINSKY_DAEMON_LOG" ]; then
        _recent_fails=$(tail -20 "$MINSKY_DAEMON_LOG" | grep -c 'spawn-failed' 2>/dev/null || echo 0)
        if [ "$_recent_fails" -ge 3 ]; then
          echo "  ⚠️  3+ recent spawn failures. Check: devin --version / claude --version"
          _help_needed=1
        fi
      fi

      # Check for blocked tasks in TASKS.md
      if [ -n "$host_dir" ] && [ -f "$host_dir/TASKS.md" ]; then
        _blocked=$(grep -c '\*\*Blocked\*\*:' "$host_dir/TASKS.md" 2>/dev/null || echo 0)
        if [ "$_blocked" -gt 0 ]; then
          echo "  📋 $_blocked tasks marked as blocked — review TASKS.md"
          _help_needed=1
        fi
      fi

      # Check for stale daemon (no new log lines in 20+ min)
      if [ -f "$MINSKY_DAEMON_LOG" ]; then
        _log_age=$(( $(date +%s) - $(stat -f %m "$MINSKY_DAEMON_LOG" 2>/dev/null || stat -c %Y "$MINSKY_DAEMON_LOG" 2>/dev/null || echo 0) ))
        if [ "$_log_age" -gt 1200 ]; then
          echo "  ⚠️  Daemon log not updated in $((_log_age / 60))min — may be stuck"
          _help_needed=1
        fi
      fi

      if [ "$_help_needed" -eq 0 ]; then
        echo "  ✅ No human action needed — minsky is running autonomously"
      fi
      echo ""

      # Log tail
      echo "  📝 LOG (last 5 lines)"
      echo "  ────────────────────────────────────────────────────────"
      if [ -f "$MINSKY_DAEMON_LOG" ]; then
        tail -5 "$MINSKY_DAEMON_LOG" | sed 's/^/  /'
      else
        echo "  (no log)"
      fi

      sleep 10
    done
    ;;
esac

# ── 2. Resolve the minsky repo via the pure `resolveMinskyRepo` ─
#
# The resolver lives in TypeScript; ship a tiny node inline-eval that
# calls the compiled `dist/shim-resolve.js` OR falls back to tsx if the
# package isn't built yet (dev ergonomics — the operator should never
# have to `pnpm build` before the shim works).
SHIM_HOME="${HOME:-/root}"
SHIM_ENV_REPO="${MINSKY_REPO:-}"

MINSKY_REPO_PATH="$(node --input-type=module -e "
  import { existsSync } from 'node:fs';
  import { homedir } from 'node:os';

  // Inline copy of the resolver's deterministic chain. Keeps the
  // shim zero-dependency: no need to resolve the minsky repo to
  // locate the resolver that tells us where the minsky repo is.
  // Search order is most-recommended layout first, niche layouts after.
  const FALLBACKS = [
    'minsky',
    'code/minsky',
    'src/minsky',
    'apps/minsky',
    'apps/tooling/minsky',
  ];
  const home = homedir();
  const envRepo = process.env.MINSKY_REPO;
  if (envRepo && envRepo.length > 0) {
    if (existsSync(envRepo)) {
      process.stdout.write(envRepo);
      process.exit(0);
    }
    process.stderr.write(\`minsky: MINSKY_REPO=\${envRepo} but path does not exist\\n\`);
    process.exit(1);
  }
  for (const rel of FALLBACKS) {
    const full = \`\${home}/\${rel}\`;
    if (existsSync(full)) {
      process.stdout.write(full);
      process.exit(0);
    }
  }
  process.stderr.write('minsky: could not find the minsky repo. Looked at MINSKY_REPO (unset), ~/minsky, ~/code/minsky, ~/src/minsky, ~/apps/minsky. Set MINSKY_REPO=/path/to/minsky or clone to ~/minsky.\\n');
  process.exit(1);
" 2>&1)"
RESOLVE_EXIT=$?
if [ $RESOLVE_EXIT -ne 0 ]; then
  echo "$MINSKY_REPO_PATH" >&2
  exit 1
fi
export SHIM_HOME SHIM_ENV_REPO

# ── 3. Locate the runner bin + forward ──────────────────────
# Pre-scan args for dispatches that DON'T need the Node runner bin
# (--transform → bin/minsky-default-session.sh; --bash-runner →
# bin/minsky-run.sh). Otherwise the runner-bin existence check would
# require `pnpm install` even when the operator is dogfooding a pure-
# bash flow. The full arg parse later still owns flag stripping; this
# is just a "do we need the Node runner at all?" probe.
_NEEDS_NODE_RUNNER=1
for arg in "$@"; do
  case "$arg" in
    --transform|--bash-runner) _NEEDS_NODE_RUNNER=0 ;;
  esac
done
RUNNER_BIN="$MINSKY_REPO_PATH/novel/cross-repo-runner/bin/minsky-run.mjs"
if [ "$_NEEDS_NODE_RUNNER" = "1" ] && [ ! -f "$RUNNER_BIN" ]; then
  echo "minsky: resolved repo $MINSKY_REPO_PATH but runner bin not found at $RUNNER_BIN. Run \`cd $MINSKY_REPO_PATH && pnpm install\` first." >&2
  exit 1
fi

# ── 3b. Parse --local flag ─────────────────────────────────
# `minsky --local [args...]` sets the env vars for local-only mode
# and strips --local from the args before forwarding. Combinable
# with --daemon: `minsky --local --daemon --hosts-dir <repos-parent>`.
#
# Also parses --bash-runner: when set (or MINSKY_BASH_RUNNER=1),
# dispatch to bin/minsky-run.sh (the Path A bash port) instead of the
# Node runner. Opt-in only — default stays the Node runner. Phase 7c
# of `docs/plans/2026-05-24-path-a-aggressive-cut.md`. Operators use
# this to live-fire-smoke the bash port; once parity is confirmed
# end-to-end the default flips and the Node runner gets deleted in
# Phase 7b.
MINSKY_ARGS=()
USE_BASH_RUNNER="${MINSKY_BASH_RUNNER:-0}"
USE_TRANSFORM="0"
for arg in "$@"; do
  if [ "$arg" = "--local" ]; then
    export MINSKY_LLM_PROVIDER="local-only"
    export MINSKY_LOCAL_LLM=1
  elif [ "$arg" = "--bash-runner" ]; then
    USE_BASH_RUNNER=1
  elif [ "$arg" = "--transform" ]; then
    # Vertical-slice-3 flag: dispatch to bin/minsky-default-session.sh
    # against $PWD. Composes bootstrap (#807) + baseline (#812) + run
    # (#797 + #808) + report (#813). See bin/minsky-default-session.sh
    # for the orchestration. The remaining args are forwarded so
    # operators can pass `--max-hours`, `--baseline-only`, etc.
    USE_TRANSFORM=1
  else
    MINSKY_ARGS+=("$arg")
  fi
done
if [ "${#MINSKY_ARGS[@]}" -gt 0 ]; then
  set -- "${MINSKY_ARGS[@]}"
else
  set --
fi

# Survive terminal close (SIGHUP). IDE terminals (Windsurf, Cursor,
# VS Code) send SIGHUP to child processes when the terminal tab or
# window closes. An autonomous minsky run (10h+) must not die because
# the operator restarted their IDE. `trap '' HUP` sets the signal
# disposition to "ignore" in this shell; POSIX guarantees ignored
# signals survive exec, so the node process inherits the immunity.
# SIGTERM from `minsky stop` is unaffected (not trapped here).
# Note: `nohup` binary achieves the same but CyberArk EPM blocks it
# on some corporate Macs — this builtin approach is equivalent.
trap '' HUP

# ── 3b. Smart auto-attach ────────────────────────────────────
# When invoked without subcommands, do the smartest thing:
#   1. Run health checks (doctor) FIRST — if any critical check fails,
#      print + exit non-zero. The operator's machine isn't ready.
#   2. If a daemon is already running for $PWD → attach with watch.
#   3. Otherwise → start one in daemon mode + auto-install persistence
#      + attach.
# This makes `minsky` in a folder always do the right thing:
#   - machine broken? → tell the operator exactly what to fix
#   - daemon running for this host? → attach (watch)
#   - no daemon? → start one in daemon mode + attach (watch)
# Operator directive 2026-05-18: "run minsky in a folder → it just works"
# Extended 2026-05-25 with the doctor preamble (rule #16 CLI consolidation
# corollary — `minsky` with no args owns the smartest defaults).

_daemon_running_for_host() {
  # Returns 0 if a daemon is running and targeting a path that contains $1
  [ -f "$MINSKY_DAEMON_PID" ] || return 1
  local pid
  pid=$(cat "$MINSKY_DAEMON_PID" 2>/dev/null) || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  # Check if the running daemon targets the requested host
  ps -p "$pid" -o args= 2>/dev/null | grep -q "$1" 2>/dev/null
}

# If no subcommand and no --daemon flag, try smart auto-attach.
# Skip auto-attach when --transform or --bash-runner is in the
# original arg list — those dispatch paths do not want the "attach
# to running daemon" UX. (Note: the arg-strip block above already
# consumed --transform / --bash-runner from $@, so we read the
# USE_TRANSFORM / USE_BASH_RUNNER vars set there.)
if [ "$USE_TRANSFORM" != "1" ] && [ "$USE_BASH_RUNNER" != "1" ] && [ "${1:-}" != "--daemon" ] && [ "${1:-}" != "status" ] && [ "${1:-}" != "stop" ] && [ "${1:-}" != "logs" ] && [ "${1:-}" != "watch" ] && [ "${1:-}" != "doctor" ]; then
  # Step 1: doctor preamble. Run the existing `doctor` check; on
  # critical fail, print + exit. Operator gets actionable hints.
  # Skipped when MINSKY_SKIP_DOCTOR=1 (escape hatch for known-degraded
  # environments where the operator wants to attach anyway).
  if [ "${MINSKY_SKIP_DOCTOR:-0}" != "1" ]; then
    # Run doctor in quiet mode — only FAIL/WARN lines print. If it
    # exits non-zero, re-run loud so the operator sees what failed.
    if ! "$0" doctor --quiet >/dev/null 2>&1; then
      echo ""
      echo "minsky: pre-flight failed. Health-check details:"
      echo ""
      "$0" doctor || true
      echo ""
      echo "minsky: fix the FAIL lines above, then re-run \`minsky\` (or set MINSKY_SKIP_DOCTOR=1 to bypass)."
      exit 1
    fi
  fi

  # Determine the target host from args or cwd
  _target_host=""
  for _a in "$@"; do
    case "$_a" in
      --host) _next_is_host=1 ;;
      --host=*) _target_host="${_a#--host=}" ;;
      *) [ "${_next_is_host:-}" = "1" ] && _target_host="$_a" && _next_is_host="" ;;
    esac
  done
  [ -z "$_target_host" ] && _target_host="$(pwd)"

  if _daemon_running_for_host "$_target_host"; then
    _pid=$(cat "$MINSKY_DAEMON_PID")
    echo "minsky: daemon already running (PID $_pid) for $(basename "$_target_host")"
    echo "        attaching with watch... (Ctrl-C to detach, daemon keeps running)"
    echo ""
    sleep 1
    exec "$0" watch "$_target_host"
  fi

  # No daemon running — start one, auto-install launchd persistence, attach.
  # Persistence is DEFAULT — minsky should survive reboots without extra steps.
  echo "minsky: no daemon running for $(basename "$_target_host"). Starting..."
  "$0" --daemon --host "$_target_host"

  # Auto-install launchd plist if not already installed (macOS only).
  # This makes the daemon survive reboots by default. The operator
  # can remove it with `minsky uninstall-daemon`.
  if [ "$(uname)" = "Darwin" ] && ! launchctl list 2>/dev/null | grep -q 'com.minsky.daemon'; then
    echo "minsky: installing launchd persistence (survives reboot)..."
    "$0" install-daemon "$_target_host" 2>/dev/null || true
  fi

  sleep 2
  exec "$0" watch "$_target_host"
fi

# ── 4. Daemon mode (--daemon) ────────────────────────────────
# `minsky --daemon [args...]` backgrounds the runner, logs to
# ~/.minsky/daemon.log, writes a PID file, and exits immediately.
# The process survives terminal close + IDE restart (SIGHUP-immune
# from the trap above + fully detached from the controlling TTY).
#
# Lifecycle:
#   minsky --daemon --hosts-dir <repos-parent>   → start
#   minsky status                                → PID + uptime + log tail
#   minsky logs                                  → tail -f daemon.log
#   minsky stop                                  → SIGTERM → graceful drain
if [ "${1:-}" = "--daemon" ]; then
  shift  # consume --daemon, forward remaining args to minsky-run

  # Guard: don't start a second daemon
  if [ -f "$MINSKY_DAEMON_PID" ]; then
    existing_pid=$(cat "$MINSKY_DAEMON_PID")
    if kill -0 "$existing_pid" 2>/dev/null; then
      echo "minsky: daemon already running (PID $existing_pid). Stop it first: minsky stop" >&2
      exit 1
    fi
    # Stale PID from a crash/reboot — clean up
    echo "minsky: cleaning stale PID $existing_pid (process not running)"
    rm -f "$MINSKY_DAEMON_PID"
  fi

  mkdir -p "$MINSKY_STATE_DIR"

  # Crash-recovery for the host repo. Delegates to the
  # `reset-host-if-crashed` subcommand which:
  #   - keeps the working tree intact if `<sidecar>/graceful-stop`
  #     exists (the previous `minsky stop` wrote it);
  #   - stashes any dirty state with a recoverable label and then
  #     checks out the default branch if the sentinel is missing
  #     (crashed shutdown).
  # The old in-line block ran `git clean -fd` which violates the
  # global multi-agent git safety rules (deletes other agents'
  # untracked files). Now: stash, never delete. (rule #17 fix,
  # 2026-05-19; see TASKS.md `minsky-bin-git-clean-fd-multi-agent-
  # safety-violation`.)
  _host_arg=""
  _prev_was_host=0
  for _a in "$@"; do
    if [ "$_prev_was_host" = "1" ]; then
      _host_arg="$_a"
      break
    fi
    [ "$_a" = "--host" ] && _prev_was_host=1 || _prev_was_host=0
  done
  if [ -n "$_host_arg" ] && [ -d "$_host_arg/.git" ]; then
    "$0" reset-host-if-crashed \
      --host "$_host_arg" \
      --sentinel "$_host_arg/.minsky/graceful-stop" || true
  fi

  # Background the runner. stdin from /dev/null, stdout+stderr to the
  # daemon log (append — preserves history across restarts). The
  # subshell + disown detaches from the controlling terminal's process
  # group so the node process is not a child of this shell.
  MINSKY_NON_INTERACTIVE=1 node "$RUNNER_BIN" "$@" \
    < /dev/null \
    >> "$MINSKY_DAEMON_LOG" 2>&1 &
  daemon_pid=$!
  disown "$daemon_pid" 2>/dev/null || true
  echo "$daemon_pid" > "$MINSKY_DAEMON_PID"

  echo "minsky daemon started (PID $daemon_pid)"
  echo "  log: $MINSKY_DAEMON_LOG"
  echo "  status: minsky status"
  echo "  follow: minsky logs"
  echo "  stop:   minsky stop"
  exit 0
fi

# ── 5. Foreground mode (default) ─────────────────────────────
# Forward every arg verbatim. The runner bin itself handles `--help`,
# cwd auto-detect, countdown banner, autonomous defaults, etc.
# SIGHUP-immune from the trap above.
if [ "$USE_TRANSFORM" = "1" ]; then
  # Vertical slice 3 dispatch (TASKS.md `minsky-default-8h-repo-
  # transformation` P0): orchestrate bootstrap + baseline + run +
  # report against $PWD. See bin/minsky-default-session.sh.
  TRANSFORM_BIN="$MINSKY_REPO_PATH/bin/minsky-default-session.sh"
  if [ ! -x "$TRANSFORM_BIN" ]; then
    echo "minsky: --transform requested but $TRANSFORM_BIN is not executable. Run \`chmod +x $TRANSFORM_BIN\`." >&2
    exit 1
  fi
  echo "minsky: --transform → orchestrating bootstrap + baseline + run + report against $PWD" >&2
  exec bash "$TRANSFORM_BIN" "$PWD" "$@"
fi
if [ "$USE_BASH_RUNNER" = "1" ]; then
  # Phase 7c: dispatch to the Path A bash port instead of the Node
  # runner. Only the multi-host walker path is supported today; bash
  # rejects unknown flags with exit 2. See `docs/plans/2026-05-24-
  # path-a-aggressive-cut.md` § Phase 7c for the scope.
  BASH_RUNNER_BIN="$MINSKY_REPO_PATH/bin/minsky-run.sh"
  if [ ! -x "$BASH_RUNNER_BIN" ]; then
    echo "minsky: --bash-runner requested but $BASH_RUNNER_BIN is not executable. Run \`chmod +x $BASH_RUNNER_BIN\`." >&2
    exit 1
  fi
  echo "minsky: using bash runner ($BASH_RUNNER_BIN) — Phase 7c opt-in" >&2
  exec bash "$BASH_RUNNER_BIN" "$@"
fi
exec node "$RUNNER_BIN" "$@"
