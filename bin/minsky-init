#!/usr/bin/env bash
# bin/minsky-init — the single one-command bootstrap entry point.
#
# Why this file exists: today installing minsky requires a chain of
# manual steps (`git clone` + `pnpm install` + per-machine
# `~/.minsky/config.json` + an OMC plugin install). Each extra step is a
# place a new operator can fall off the path. `bin/minsky-init` collapses
# the whole chain into one command so time-to-first-iteration drops from
# >10 min (clone + install + config + troubleshoot) to <3 min on a machine
# that already has Node ≥20 — the M1 adoption gate.
#
# Constitution note: this entry point deliberately does NOT call the
# deprecated legacy setup script (docs/DEPRECATED.md § 5 names `minsky
# init` as its replacement). It composes the two NON-deprecated primitives
# instead: `pnpm install` (whose `prepare` hook builds dist/ + installs the
# git hooks) and `bin/minsky init` (the canonical writer of
# `~/.minsky/config.json`). Don't reinvent (rule #1); use the replacement,
# not the deprecated surface (AGENTS.md §"check DEPRECATED.md first").
#
# Contract (the 5-action plan, run in order; idempotent — re-runs converge):
#   (a) detect a git repo (default: $PWD; else first positional arg). If the
#       target is not a git repo, abort with exit 2 + actionable guidance —
#       no silent fallback (rule #6 "let it crash" / loud-crash on misconfig).
#   (b) verify the toolchain: Node ≥20 (loud-crash with the exact install
#       command if absent/old); pnpm (install via `corepack enable` when
#       missing — corepack ships with Node ≥20, so this is zero extra deps).
#   (c) run `pnpm install` in the minsky repo (idempotent — its `prepare`
#       hook compiles dist/ and installs the lefthook git hooks). Skippable
#       with --skip-install for already-installed checkouts.
#   (d) write the per-machine config by delegating to `bin/minsky init
#       <host>` (single source of truth for `~/.minsky/config.json`).
#   (e) run `minsky doctor` and report GREEN / YELLOW / RED, then print the
#       one-line command to start: `minsky`.
#
# Usage:
#   bin/minsky-init [<repo-dir>]    # bootstrap <repo-dir> (default: $PWD)
#   bin/minsky-init --doctor        # run the toolchain/doctor checks only,
#                                   # no mutations (dry diagnostic)
#   bin/minsky-init --skip-install  # skip `pnpm install` (config + doctor
#                                   # only — for already-installed checkouts)
#   bin/minsky-init --help          # print this header
#
# Env:
#   MINSKY_STATE_DIR   — override ~/.minsky (integration tests set this).
#
# Exit codes:
#   0  — bootstrapped (doctor GREEN or YELLOW); next step printed.
#   1  — doctor RED, or `pnpm install` failed.
#   2  — target is not a git repo, or bad CLI args.
#   3  — Node missing or < the minimum major version (toolchain unmet).
#
# Anchor: Forsgren/Humble/Kim *Accelerate* 2018 (lead time — the install IS
# the first lead-time metric); Krug *Don't Make Me Think* 2014 (one obvious
# path); rule #1 (compose `pnpm install` + `bin/minsky init` — don't
# reinvent); rule #11 "default by default" (one command does the right
# thing for the 90% case; flags are the 10% drill-down).

set -euo pipefail

# Single source of truth for the minimum Node major — mirrors package.json
# `engines.node` (>=20.0.0).
MINSKY_NODE_MIN_MAJOR=20

# --- color / no-color / CI awareness ----------------------------------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && [ -z "${CI:-}" ]; then
  C_BOLD=$'\033[1m'; C_RED=$'\033[31m'; C_YELLOW=$'\033[33m'
  C_GREEN=$'\033[32m'; C_RESET=$'\033[0m'
else
  C_BOLD=""; C_RED=""; C_YELLOW=""; C_GREEN=""; C_RESET=""
fi
bold() { printf '%s%s%s\n' "$C_BOLD" "$*" "$C_RESET"; }
ok()   { printf '%s✓%s %s\n' "$C_GREEN"  "$C_RESET" "$*"; }
warn() { printf '%s⚠%s %s\n' "$C_YELLOW" "$C_RESET" "$*"; }
err()  { printf '%s✗%s %s\n' "$C_RED"    "$C_RESET" "$*" >&2; }

# --- arg parsing ------------------------------------------------------
MODE="bootstrap"
SKIP_INSTALL=0
TARGET=""

while [ $# -gt 0 ]; do
  case "$1" in
    --doctor)       MODE="doctor"; shift ;;
    --skip-install) SKIP_INSTALL=1; shift ;;
    -h|--help)
      # Print the leading documentation block of this script.
      sed -n '2,/^set -euo/p' "$0" | sed -e 's/^# \?//' -e '$d'
      exit 0
      ;;
    -*)
      err "minsky-init: unknown flag: $1"
      err "  run with --help for usage"
      exit 2
      ;;
    *)
      if [ -z "$TARGET" ]; then
        TARGET="$1"
      else
        err "minsky-init: unexpected positional arg: $1"
        exit 2
      fi
      shift
      ;;
  esac
done

# --- resolve minsky repo root (this script lives in bin/) -------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MINSKY_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MINSKY_BIN="$MINSKY_ROOT/bin/minsky"

# --- (a) detect git repo ----------------------------------------------
# Default target is the current working directory: the most ergonomic
# case is "cd into your repo, run minsky-init, you're done".
TARGET="${TARGET:-$(pwd)}"
RESOLVED_TARGET="$(cd "$TARGET" 2>/dev/null && pwd || true)"
if [ -z "$RESOLVED_TARGET" ] || [ ! -d "$RESOLVED_TARGET/.git" ]; then
  err "minsky-init: '$TARGET' is not a git repo"
  err "  hint: cd into a git repo first, or run: minsky-init /path/to/repo"
  err "  (minsky governs an existing repo; it does not create one)"
  exit 2
fi

bold "minsky-init — bootstrapping $(basename "$RESOLVED_TARGET")"

# --- (b) verify toolchain: Node ≥ min major, pnpm via corepack --------
check_node_major() {
  local v
  v=$(node --version 2>/dev/null) || return 1
  v=${v#v}            # strip leading "v"
  v=${v%%.*}          # take the major segment
  case "$v" in
    *[!0-9]*|"") return 1 ;;
    *) printf '%s' "$v" ;;
  esac
}

NODE_MAJOR="$(check_node_major || true)"
if [ -z "$NODE_MAJOR" ]; then
  err "minsky-init: Node is not on PATH"
  err "  install Node ≥${MINSKY_NODE_MIN_MAJOR} then re-run. Recommended:"
  err "    fnm:           fnm install ${MINSKY_NODE_MIN_MAJOR} && fnm use ${MINSKY_NODE_MIN_MAJOR}"
  err "    homebrew(mac): brew install node@${MINSKY_NODE_MIN_MAJOR}"
  err "    nodejs.org:    https://nodejs.org (LTS ≥${MINSKY_NODE_MIN_MAJOR})"
  exit 3
fi
if [ "$NODE_MAJOR" -lt "$MINSKY_NODE_MIN_MAJOR" ]; then
  err "minsky-init: Node v${NODE_MAJOR} is too old (need ≥${MINSKY_NODE_MIN_MAJOR})"
  err "  upgrade then re-run. e.g.: fnm install ${MINSKY_NODE_MIN_MAJOR} && fnm use ${MINSKY_NODE_MIN_MAJOR}"
  exit 3
fi
ok "Node v${NODE_MAJOR} (≥${MINSKY_NODE_MIN_MAJOR})"

# --doctor mode: toolchain + doctor only, no mutations -----------------
if [ "$MODE" = "doctor" ]; then
  if command -v pnpm >/dev/null 2>&1; then
    ok "pnpm $(pnpm --version 2>/dev/null || echo '(present)')"
  else
    warn "pnpm not on PATH — bootstrap would enable it via corepack"
  fi
  bold "running minsky doctor (read-only)…"
  if [ -x "$MINSKY_BIN" ]; then
    ( cd "$RESOLVED_TARGET" && "$MINSKY_BIN" doctor ) || true
  else
    warn "bin/minsky not executable at $MINSKY_BIN"
  fi
  exit 0
fi

# pnpm: install via corepack (ships with Node ≥20) when missing. Zero
# extra deps — corepack is the Node-blessed package-manager shim.
if command -v pnpm >/dev/null 2>&1; then
  ok "pnpm $(pnpm --version 2>/dev/null || echo '(present)')"
elif command -v corepack >/dev/null 2>&1; then
  bold "enabling pnpm via corepack…"
  if corepack enable >/dev/null 2>&1 && corepack prepare pnpm@latest --activate >/dev/null 2>&1; then
    ok "pnpm enabled via corepack"
  else
    warn "corepack enable failed — install pnpm manually: npm i -g pnpm"
  fi
else
  warn "neither pnpm nor corepack found — install pnpm manually: npm i -g pnpm"
fi

# --- (c) pnpm install (builds dist/ + installs git hooks via prepare) --
# Compose the existing install path rather than re-implement a bootstrap
# (rule #1). `prepare` runs `tsc -b` + lefthook install + toolchain check;
# re-running is idempotent. Done in the minsky repo, not the host.
if [ "$SKIP_INSTALL" -eq 0 ]; then
  if command -v pnpm >/dev/null 2>&1; then
    bold "running pnpm install (builds dist/ + installs git hooks)…"
    if ( cd "$MINSKY_ROOT" && pnpm install ); then
      ok "pnpm install complete"
    else
      err "minsky-init: pnpm install failed — see its output above"
      err "  re-run after fixing, or: minsky-init --skip-install (config + doctor only)"
      exit 1
    fi
  else
    warn "pnpm unavailable — skipping install (config + doctor only)"
  fi
else
  ok "pnpm install skipped (--skip-install)"
fi

# --- (d) write per-machine config via bin/minsky init -----------------
# Single source of truth for ~/.minsky/config.json lives in `bin/minsky
# init`; delegate so the two never drift (rule #1 / one canonical path).
if [ -x "$MINSKY_BIN" ]; then
  bold "writing per-machine config…"
  if "$MINSKY_BIN" init "$RESOLVED_TARGET"; then
    : # bin/minsky init prints its own success banner
  else
    err "minsky-init: 'minsky init' failed for $RESOLVED_TARGET"
    exit 1
  fi
else
  err "minsky-init: bin/minsky not executable at $MINSKY_BIN"
  exit 1
fi

# --- (e) run minsky doctor + report + next step -----------------------
bold "running minsky doctor…"
DOCTOR_RC=0
( cd "$RESOLVED_TARGET" && "$MINSKY_BIN" doctor ) || DOCTOR_RC=$?

echo
if [ "$DOCTOR_RC" -eq 0 ]; then
  ok "GREEN — minsky doctor passed"
  bold "Next: start an iteration"
  printf '  cd %s\n' "$RESOLVED_TARGET"
  printf '  minsky\n'
  exit 0
else
  warn "doctor reported issues (exit $DOCTOR_RC) — review the output above"
  warn "  many warnings are non-fatal (optional CLIs). Fix RED items, then:"
  printf '  cd %s && minsky\n' "$RESOLVED_TARGET"
  # Doctor non-zero is a soft signal here: the bootstrap itself succeeded
  # (config written, install ran). Surface RED as exit 1 so CI/automation
  # can branch on it; the operator already has the actionable next line.
  exit 1
fi
