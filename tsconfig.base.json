{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    // vitest 4 changed its type-export structure: its ambient type chunks land
    // in the program's default `@types` scope and suppress tsc's automatic
    // inclusion of `@types/node`, so node globals (URL, Response, node:fs, …)
    // stop resolving. Pinning `types: ["node"]` restores them. Matches the
    // existing `types: ["node"]` in scripts/, user-stories/, dashboard-web/.
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
