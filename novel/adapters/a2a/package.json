{
  "name": "@minsky/a2a",
  "version": "0.0.0",
  "private": true,
  "description": "A2A adapter — interface (Adapter pattern, Gamma 1994) + StubA2A test fake + A2AOpenHands scaffold (real google-a2a-python bridge pending 2026-06-01 OpenHands runtime).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --root .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@minsky/adapter-types": "workspace:*"
  }
}
