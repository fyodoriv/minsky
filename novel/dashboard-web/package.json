{
  "name": "@minsky/dashboard-web",
  "version": "0.0.0",
  "private": true,
  "description": "SSR web dashboard (Hono v4) — sub-task 1/4 of dashboard-web-v0; v0 ships the skeleton + a single placeholder metric stub. Card & Mackinlay 1999 (information visualization); Wilkie, RED Method, 2018.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
