{
  "name": "@minsky/tick-loop",
  "version": "0.0.0",
  "private": true,
  "description": "Deterministic mock-tick daemon for the in-process 10-min smoke (sub-task 2/3 of first-integration-test). Loops claim → mock-anthropic-call → complete on a configurable cadence.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "tick-loop": "./bin/tick-loop.mjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "bin/tick-loop.mjs",
    "README.md",
    "test/fixtures/**/*.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --root .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@minsky/budget-guard": "workspace:*",
    "@minsky/notifier": "workspace:*",
    "@minsky/observability": "workspace:*",
    "@minsky/token-monitor": "workspace:*"
  }
}
