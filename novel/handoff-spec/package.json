{
  "name": "@minsky/handoff-spec",
  "version": "0.0.0",
  "private": true,
  "description": "Spec + parser + validator for persona-to-persona handoff records (actor message-passing with continuation, Hewitt 1973).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/**/*.js", "dist/**/*.d.ts", "spec.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --root .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
