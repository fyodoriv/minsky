# Minsky tick-loop — the per-iteration scheduler that picks the next task,
# claims it, runs OMC, and ships the result. Restart-on-failure with
# exponential backoff so a systematic failure doesn't hammer the API.
#
# Pattern: OTP supervision behaviour, "transient" restart strategy
# (Armstrong, *Programming Erlang*, 2007). systemd's `Restart=on-failure` +
# `RestartSec` + `RestartSteps` is the closest-fitting POSIX equivalent.
# Conformance: partial — see ARCHITECTURE.md § "Process supervision tree"
# and vision.md § "Pattern conformance index" row 4.
#
# Placeholders (substituted by setup.sh via envsubst):
#   ${MINSKY_HOME}   — absolute path to the minsky repo checkout

[Unit]
Description=Minsky tick-loop — picks the next task and ships it
PartOf=minsky-supervisor.target
After=network-online.target minsky-budget-guard.service
Requires=minsky-budget-guard.service

[Service]
Type=simple
WorkingDirectory=${MINSKY_HOME}
Environment=MINSKY_HOME=${MINSKY_HOME}
# Safe-rollout window closed 2026-05-04 — Minsky-on-itself validated
# end-to-end (launchd plist paths fixed #143; macOS portability fixes
# #144; node-PATH-resolution #145; stdout flush #146). Production
# default is `ProcessSpawnStrategy` (real `claude --print` per
# iteration). To re-enter dry-run temporarily (e.g., for a chaos
# test or a fresh-install smoke), uncomment the Environment= line
# below, `pnpm dogfood` to reload, then re-comment it.
# Environment=MINSKY_TICK_DRY_RUN=1
# Daily-changelog umbrella opt-in (acceptance criterion (3) of
# `daily-changelog-for-humans`). Enables BOTH `runDaemon` seams the CLI
# constructs under this single env var: the changelog-mode `claude --print`
# author (per-day, gated by `## YYYY-MM-DD` H2 in CHANGELOG.md) AND the
# per-day metric-snapshot capture (`pnpm changelog:snapshot --date <date>`,
# gated by `.minsky/metric-snapshots/<date>.json` presence). Both gates are
# idempotent — exactly one fire per UTC date — so leaving this on across
# many iterations is safe by design (rule #2 — file presence IS the
# "this happened" record). Drop the flag to revert to substrate-inert.
Environment=MINSKY_CHANGELOG_ENABLE=1
# Post-task CTO-audit umbrella opt-in (sub-step (d) of `post-task-cto-audit`).
# Constructs the `CtoAuditSeam` the daemon dispatches into after every
# successfully-completed iteration that shipped a real change (commit on the
# branch OR PR opened — noop iterations are gated out by `shouldRunCtoAudit`).
# The audit spawns a separate `claude --print` invocation with a CTO-mode
# prompt header (`CTO_PROMPT_HEADER`) that asks for the single highest-leverage
# next task; output is committed to TASKS.md on a dedicated branch
# (`audit/<UTC-date>-<original-task-id>`) and a PR is opened with label
# `minsky:cto-audit` for operator review (sub-step (e)). The cap-1-per-task
# contract (sub-step (f)) is enforced by a file-backed lock at
# `<MINSKY_HOME>/.minsky/cto-audit-lock/<task-id>` that survives daemon restart.
# Per-iteration override: set `MINSKY_CTO_AUDIT=off` to skip a single fire
# without unwinding the seam (sub-step (c)). Operator runbook:
# `docs/post-task-cto-audit.md`. Pivot trigger (rule #9): >5 audit-PRs/day
# means tighten the brief; <1/week sustained 4 weeks means retire.
Environment=MINSKY_CTO_AUDIT_ENABLE=1
# Supervisor-sandbox mode (vision.md § 13.3 — third minimum-bar item of
# rule #13). Resolver substrate ships in `novel/tick-loop/src/sandbox-mode.ts`
# (PR #332); startup banner consumes it (PR #335). Unset / `'off'` is the
# substrate-inert default — no syscall restrictions applied. Operator
# ramp path: uncomment to `'warn-only'` for the 14-day soak (logs every
# disallowed access, blocks nothing); flip to `'enforce'` after the soak.
# An unrecognised value (typo) falls back to `'off'` and surfaces a
# WARNING line in the supervisor log (rule #6 visible-not-silent).
# Substrate-inert until later slices wire `SystemCallFilter`, `ProtectSystem`,
# `PrivateTmp`, and `RestrictAddressFamilies` — flipping to `enforce` today
# does not actually sandbox anything.
# Environment=MINSKY_SANDBOX=off
ExecStart=/bin/sh ${MINSKY_HOME}/distribution/systemd/run-tick-loop.sh

# Sandboxing — stage 0 of `supervisor-sandbox-syscall-restriction`
# (vision.md rule #13 item 3 — security-privacy is Minsky's #2 priority
# after performance). Pinned by scripts/check-supervisor-sandbox-hardening.mjs.
# Anchor: systemd.exec(5) "Sandboxing" section — every directive below
# is documented as having no effect on a normal long-lived Node.js
# process that reads/writes its WorkingDirectory and spawns child
# processes AND is safe under `systemctl --user` (which is how every
# Minsky supervisor unit runs by design).
#
# Why the `ProtectKernel{Tunables,Modules,Logs}=` triple is NOT here:
# each one implies a `CapabilityBoundingSet=~CAP_*` drop (CAP_SYS_RAWIO,
# CAP_SYS_MODULE, CAP_SYSLOG respectively), and prctl(PR_CAPBSET_DROP)
# requires CAP_SETPCAP. A user-mode systemd session typically lacks
# CAP_SETPCAP, so the unit fails to start with `status=218/CAPABILITIES`
# (observed: linux-supervisor-integration CI on PR #347, 2026-05-07).
# The triple stays deferred to a later stage that ships only when
# system-mode units are introduced (currently out of scope per
# vision.md — Minsky supervises itself as the operator, not as root).
#
# Filesystem/network restrictions (ProtectSystem=, ProtectHome=,
# RestrictAddressFamilies=, SystemCallFilter=) are similarly deferred
# to stage 1+ behind the dry-run + warn-only ramp.
NoNewPrivileges=yes
PrivateTmp=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictRealtime=yes

# Erlang-style "transient" restart: only on non-zero exit (let-it-crash
# discipline, rule #6). Backoff caps the API hammering on systematic failures.
Restart=on-failure
RestartSec=5
StartLimitIntervalSec=300
StartLimitBurst=10

# StandardOutput/StandardError → journal (queryable via journalctl --user)
StandardOutput=journal
StandardError=journal
SyslogIdentifier=minsky-tick-loop

[Install]
WantedBy=minsky-supervisor.target
