{
  "$schema": "./schema/minsky-shortcut.schema.json",
  "name": "Minsky · pause",
  "description": "Pause the autonomous loop. POSTs {\"paused\": true} to /control on the local Tailscale-reachable dashboard. Mirrors resume.shortcut.json.",
  "shortcut_kind": "post-control",
  "endpoint": {
    "method": "POST",
    "url": "http://<tailscale-host>:8080/control",
    "url_assembly": {
      "action": "Combine Text",
      "parts": ["http://", "${host}", ":8080/control"],
      "host_variable": "host",
      "host_set_by": "setup-host.shortcut.json"
    },
    "tailscale_host_var": "MINSKY_TAILSCALE_HOST",
    "port": 8080,
    "path": "/control",
    "request_body": {
      "paused": true
    },
    "request_content_type": "application/json"
  },
  "display": {
    "action": "Show Result",
    "format": "Paused"
  },
  "watch_surface": false,
  "anchor": "Beyer et al., SRE 2016, Ch. 17 (operator escape hatch / kill switch); user-story 002 (pause from iPhone).",
  "build_runbook": "../README.md"
}
