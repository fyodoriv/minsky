{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minsky.local/schema/minsky-shortcut.schema.json",
  "title": "Minsky Shortcut config",
  "description": "Operator-buildable config manifest for an Apple Shortcut. The smoke test asserts URL / port / path / metric-mapping consistency; the operator builds the Shortcut on iPhone per distribution/shortcuts/README.md. Pivot rationale (JSON config vs native .shortcut binary) is documented in the README.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "description",
    "shortcut_kind",
    "endpoint",
    "display",
    "watch_surface",
    "anchor",
    "build_runbook"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "shortcut_kind": {
      "type": "string",
      "enum": ["fetch-and-show", "post-control"]
    },
    "endpoint": {
      "type": "object",
      "required": ["method", "url", "port", "path"],
      "properties": {
        "method": { "type": "string", "enum": ["GET", "POST"] },
        "url": { "type": "string", "format": "uri" },
        "tailscale_host_var": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "path": { "type": "string", "pattern": "^/[A-Za-z0-9._/-]*$" },
        "request_body": { "type": "object" },
        "request_content_type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "extract": {
      "type": "object",
      "required": ["action", "key", "metric_id"],
      "properties": {
        "action": { "type": "string", "enum": ["Get Dictionary Value"] },
        "key": { "type": "string", "minLength": 1 },
        "metric_id": { "type": "string", "minLength": 1 },
        "vision_md_success_row": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    },
    "display": {
      "type": "object",
      "required": ["action", "format"],
      "properties": {
        "action": { "type": "string", "enum": ["Show Result"] },
        "format": { "type": "string", "minLength": 1 }
      }
    },
    "watch_surface": { "type": "boolean" },
    "anchor": { "type": "string", "minLength": 1 },
    "build_runbook": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": { "properties": { "shortcut_kind": { "const": "fetch-and-show" } } },
      "then": {
        "required": ["extract"],
        "properties": {
          "endpoint": { "properties": { "method": { "const": "GET" } } }
        }
      }
    },
    {
      "if": { "properties": { "shortcut_kind": { "const": "post-control" } } },
      "then": {
        "properties": {
          "endpoint": {
            "required": ["request_body"],
            "properties": { "method": { "const": "POST" } }
          }
        }
      }
    }
  ]
}
