<?xml version="1.0" encoding="UTF-8"?>
<!--
Minsky tick-loop — launchd LaunchAgent for macOS.

Pattern: OTP "transient" restart (Armstrong 2007). launchd's `KeepAlive`
with `SuccessfulExit=false` is the closest equivalent: keep alive only if
the process exited non-zero — analogous to systemd's `Restart=on-failure`.

Placeholders substituted by setup.sh via envsubst:
  ${MINSKY_HOME}   — absolute path to the minsky repo checkout

Install: copy to ~/Library/LaunchAgents/ after envsubst, then:
  launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.minsky.tick-loop.plist
  launchctl enable gui/$(id -u)/com.minsky.tick-loop
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.minsky.tick-loop</string>

    <key>WorkingDirectory</key>
    <string>${MINSKY_HOME}</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>MINSKY_HOME</key>
        <string>${MINSKY_HOME}</string>
        <!-- Safe-rollout default per `tick-loop-daemon-real-spawn-flip`:
             keeps the first prod run on the synthetic `DryRunSpawnStrategy`
             (no real `claude` subprocess fork). An operator MUST drop this
             entry to flip to full real spawn (production default = unset =
             `ProcessSpawnStrategy`). -->
        <key>MINSKY_TICK_DRY_RUN</key>
        <string>1</string>
        <!-- Anthropic plan tier (sets the 5h-window token cap). Default is
             max5 (88k tokens). Operators on Max20 (220k) or Pro (19k) MUST
             set this to match their actual subscription, otherwise the
             BudgetGuard in-tick decide() will emit spurious budget-paused
             iterations. Valid: pro / max5 / max20 / custom. -->
        <!-- <key>MINSKY_PLAN</key>
             <string>max20</string> -->
    </dict>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${MINSKY_HOME}/distribution/systemd/run-tick-loop.sh</string>
    </array>

    <!-- Restart only on non-zero exit (transient policy per Armstrong 2007). -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <!-- Backoff between respawn attempts; caps API hammering on systematic failures. -->
    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>${MINSKY_HOME}/.minsky/tick-loop.out.log</string>
    <key>StandardErrorPath</key>
    <string>${MINSKY_HOME}/.minsky/tick-loop.err.log</string>
</dict>
</plist>
