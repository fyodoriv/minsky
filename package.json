{
  "name": "minsky",
  "version": "0.0.0",
  "private": true,
  "description": "An integration distribution for autonomous Claude Code on Max5.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "prepare": "tsc -b --force && node scripts/install-lefthook-best-effort.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run test/integration/ --testTimeout=120000",
    "test:m1-tdd": "vitest run test/integration/m1-red-green.test.ts",
    "m1:metrics": "node scripts/m1-metrics-dashboard.mjs",
    "m1:observability": "node scripts/m1-observability-plan.mjs --gaps-only",
    "m1:coverage": "CI=1 pnpm test:coverage && node scripts/full-coverage-report.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test:coverage",
    "changelog:today": "node scripts/changelog-today.mjs",
    "changelog:snapshot": "node scripts/changelog-snapshot.mjs",
    "metrics:collect": "node scripts/collect-metrics.mjs",
    "metrics:render": "node scripts/metrics-render.mjs",
    "llm-provider:throughput": "node scripts/llm-provider-throughput.mjs",
    "chaos:budget-exhaust": "node scripts/chaos-budget-exhaust.mjs",
    "cto-audit:metrics": "node scripts/cto-audit-metrics.mjs",
    "daemon-pr-lint:metrics": "node scripts/daemon-pr-lint-metrics.mjs",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules\" \"#.worktrees\" \"#.minsky\" \"#.obsidian\" \"#.claude\" \"#.claire\" \"#opencode.notes.md\" \"#.aider*\"",
    "pre-pr-lint": "node scripts/run-pre-pr-lint-stack.mjs",
    "dogfood": "./setup.sh --dogfood",
    "dogfood:doctor": "./setup.sh --doctor",
    "minsky": "node novel/tick-loop/bin/minsky.mjs",
    "dogfood:ui": "PORT=${PORT:-8181} bash distribution/run-dashboard-web.sh",
    "dogfood:logs": "tail -F .minsky/tick-loop.out.log .minsky/tick-loop.err.log",
    "dogfood:status": "launchctl list 2>/dev/null | grep -i minsky || systemctl --user status minsky-supervisor.target 2>/dev/null",
    "dogfood:stop": "launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/com.minsky.tick-loop.plist 2>/dev/null; launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/com.minsky.budget-guard.plist 2>/dev/null; systemctl --user stop minsky-supervisor.target 2>/dev/null; echo 'supervisor stopped'"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@minsky/experiment-record": "workspace:*",
    "@minsky/tick-loop": "workspace:*",
    "@minsky/token-monitor": "workspace:*",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "2.1.9",
    "js-yaml": "4.1.1",
    "lefthook": "2.1.8",
    "markdownlint-cli2": "0.22.1",
    "typescript": "5.7.2",
    "vitest": "2.1.9"
  },
  "pnpm": {
    "overrides": {
      "protobufjs@<8.0.2": ">=8.0.2"
    }
  }
}
